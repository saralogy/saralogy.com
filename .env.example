# ──────────────────────────────────────────────────────────────────────────────
# saralogy.com — Environment Variables Reference
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── BUILD-TIME PUBLIC VARIABLES ───────────────────────────────────────────────
# These are inlined into the static output. Safe to expose.
# In Astro, public vars use the PUBLIC_ prefix (exposed to client-side JS).

PUBLIC_SITE_NAME=saralogy.com
PUBLIC_SITE_DESCRIPTION=AI-native marketing for DACH SMEs

# Full canonical site URL — used by @astrojs/sitemap and canonical link tags
SITE_URL=https://saralogy.com

# ── ANALYTICS (optional, future) ─────────────────────────────────────────────
# Umami or Plausible — privacy-first, GDPR-compliant alternatives to GA
# PUBLIC_UMAMI_WEBSITE_ID=your-umami-site-id
# PUBLIC_UMAMI_URL=https://analytics.your-domain.com

# Vercel Web Analytics (enabled in vercel.json — no env var needed)
# Vercel Speed Insights (enabled in vercel.json — no env var needed)

# ── CONTACT / FORMS (future) ──────────────────────────────────────────────────
# If adding a contact form via Formspark, Formspree, or similar
# PUBLIC_CONTACT_FORM_ID=your-form-id

# ── SERVER-ONLY SECRETS (never exposed to client) ────────────────────────────
# These are only accessed at build time or in Astro server endpoints.
# For a static site (output: static), these are only relevant at build time.

# Email sending (Resend — if contact form is added)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── VERCEL DASHBOARD ONLY ─────────────────────────────────────────────────────
# These values must be added in the Vercel project dashboard under
# Settings > Environment Variables. Do NOT put them in this file.
# Listed here for documentation purposes only.
#
# VERCEL_TOKEN          — API token for Vercel CLI deploys from CI
# VERCEL_ORG_ID         — Your Vercel team/org ID
# VERCEL_PROJECT_ID     — The project ID for this site
#
# How to find these:
# - VERCEL_TOKEN:      vercel.com > Account Settings > Tokens > Create
# - VERCEL_ORG_ID:     vercel.com > Team Settings > General (Team ID)
# - VERCEL_PROJECT_ID: vercel.com > Project > Settings > General (Project ID)
#   OR run: bunx vercel link   (creates .vercel/project.json locally)

# ── GITHUB SECRETS (for CI) ───────────────────────────────────────────────────
# Add these in GitHub repo > Settings > Secrets > Actions:
#
# VERCEL_TOKEN          — same token as above
# VERCEL_ORG_ID         — same org ID
# VERCEL_PROJECT_ID     — same project ID
