---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noIndex?: boolean;
  canonicalUrl?: string;
}

const {
  title,
  description,
  ogImage = "/og-default.png",
  noIndex = false,
  canonicalUrl,
} = Astro.props;

const siteUrl = "https://saralogy.com";
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageAbsolute = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="saralogy.com" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.ico" />
    <meta name="theme-color" content="#1F2937" />

    <!-- Fonts + image origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="preload" as="image" href="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&h=900&fit=crop&auto=format&q=80" />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300;12..96,400;12..96,600;12..96,700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- GTM: loaded only after cookie consent (GDPR) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
    </script>

    <slot name="head" />
    <ViewTransitions />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <!-- GTM noscript (fires only after consent via cookie banner below) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KTML68ML" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <slot />

    <!-- Cookie consent banner (GDPR opt-in, required for Germany) -->
    <div
      id="cookie-banner"
      class="fixed bottom-0 left-0 right-0 z-50 p-4 bg-gray-900 text-white"
      style="display: none;"
    >
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <p class="text-sm text-gray-300 leading-relaxed">
          This site uses Google Analytics to understand how visitors use it.
          No personal data is sold or shared.
          <a href="/privacy" class="text-white underline hover:no-underline">Privacy policy</a>.
        </p>
        <div class="flex gap-3 shrink-0">
          <button
            id="cookie-reject"
            class="text-sm text-gray-400 hover:text-white transition-colors px-4 py-2 rounded-full border border-gray-700 hover:border-gray-400"
          >
            Reject
          </button>
          <button
            id="cookie-accept"
            class="text-sm bg-white text-gray-900 px-4 py-2 rounded-full font-medium hover:bg-gray-100 transition-colors"
          >
            Accept analytics
          </button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function() {
        var banner = document.getElementById('cookie-banner');
        function readConsent() {
          try {
            return window.localStorage.getItem('cookie_consent');
          } catch (_) {
            var match = document.cookie.match(/(?:^|; )cookie_consent=([^;]+)/);
            return match ? decodeURIComponent(match[1]) : null;
          }
        }

        function writeConsent(value) {
          try {
            window.localStorage.setItem('cookie_consent', value);
          } catch (_) {
            document.cookie = 'cookie_consent=' + encodeURIComponent(value) + '; Max-Age=31536000; Path=/; SameSite=Lax';
          }
        }

        var consent = readConsent();

        // Show banner only if no decision yet
        if (!consent && banner) {
          banner.style.display = 'block';
        }

        function loadGA() {
          if (document.getElementById('gtm-script')) return;
          var s = document.createElement('script');
          s.id = 'gtm-script';
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-KTML68ML';
          document.head.appendChild(s);
        }

        document.getElementById('cookie-accept')?.addEventListener('click', function() {
          writeConsent('accepted');
          banner.style.display = 'none';
          loadGA();
        });

        document.getElementById('cookie-reject')?.addEventListener('click', function() {
          writeConsent('rejected');
          banner.style.display = 'none';
        });

        // Load GA immediately if already accepted
        if (consent === 'accepted') loadGA();

        // Track contact clicks (fires only when GA is loaded post-consent)
        document.addEventListener('click', function(e) {
          var el = e.target.closest('a');
          if (!el) return;
          if (!window.gtag) return;
          var href = el.getAttribute('href') || '';
          if (href.startsWith('mailto:')) {
            window.gtag('event', 'contact_initiated', { method: 'email', page: window.location.pathname });
          } else if (href.includes('linkedin.com')) {
            window.gtag('event', 'contact_initiated', { method: 'linkedin', page: window.location.pathname });
          } else if (href.includes('cal.com')) {
            window.gtag('event', 'contact_initiated', { method: 'calendly', page: window.location.pathname });
          }
        });
      })();
    </script>
  </body>
</html>
