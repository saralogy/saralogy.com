---
import Base from "@layouts/Base.astro";
import "../styles/global.css";
import { Marquee }    from "@components/Marquee";
import { NavHeader }  from "@components/NavHeader";
import { SiteFooter } from "@components/SiteFooter";
import { MusicPlayer } from "@components/MusicPlayer";
---

<Base
  title="Music — Indie Songwriter | Berk Saraloglu"
  description="Indie songwriter exploring production, process, and place. Writing about movement — physical, mental, creative."
>
  <Marquee client:load />
  <NavHeader client:load />

  <main class="bg-black">
    <!-- Dark hero with blended illustration -->
    <section class="relative bg-black text-white border-b border-border overflow-hidden">
      <!-- Blended face illustration background -->
      <div class="absolute inset-0 opacity-20 pointer-events-none mix-blend-screen">
        <img
          src="/images/music-header.png"
          alt="Music composition"
          class="w-full h-full object-cover object-center"
        />
      </div>

      <div class="relative max-w-[1440px] mx-auto px-6 md:px-12 pt-32 pb-32 md:pt-48 md:pb-48">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
          <div>
            <span class="text-[11px] tracking-[0.25em] uppercase text-white/50 block mb-3" style="font-family: var(--font-body)">
              ✦ Creative Work
            </span>
            <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(3rem, 7vw, 6rem); line-height: 0.95; letter-spacing: -0.03em; color: white;">
              Music.
            </h1>
          </div>
          <p class="max-w-sm text-sm text-white/70 leading-relaxed" style="font-family: var(--font-body)">
            Indie songwriter exploring production, process, and place. Writing about movement — physical, mental, and creative. Each piece is a deliberate exploration of what it takes to build something that doesn't exist yet.
          </p>
        </div>

        <!-- Static waveform decoration on dark -->
        <div class="mt-10 flex items-end gap-[3px] h-10 opacity-40" aria-hidden="true">
          {[4,7,12,9,15,11,18,14,10,16,13,8,17,12,6,14,10,18,9,15,11,7,13,16,8,12,17,10,14,6,15,11,9,16,13,7,18,12,8,14].map((h, i) => (
            <div
              class="flex-none w-[3px] bg-white"
              style={`height: ${h}px; animation: waveform-idle ${0.8 + (i % 4) * 0.15}s ease-in-out infinite alternate; animation-delay: ${i * 0.04}s`}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Music player section - dark -->
    <section class="bg-black text-white border-b border-white/10">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20">
        <MusicPlayer client:load />
      </div>
    </section>

    <!-- Why music section - dark -->
    <section class="bg-black text-white border-b border-white/10">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16">
          <div>
            <span class="text-[11px] tracking-[0.25em] uppercase text-white/50 block mb-6" style="font-family: var(--font-body)">
              ✦ Why music
            </span>
            <p class="text-sm text-white/70 leading-relaxed" style="font-family: var(--font-body)">
              Writing music and building products feed the same need: to create something that didn't exist before. Music is where I work without constraints — no market validation, no product roadmap, just the idea and the time to explore it.
            </p>
          </div>
          <div>
            <span class="text-[11px] tracking-[0.25em] uppercase text-white/50 block mb-6" style="font-family: var(--font-body)">
              ✦ The connection
            </span>
            <p class="text-sm text-white/70 leading-relaxed" style="font-family: var(--font-body)">
              The process feeds back into how I think about marketing. Both require the same skill: understanding what a person actually feels before they can name it, then building something that captures that feeling exactly.
            </p>
            <a
              href="/about"
              class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase border-b border-white/50 hover:border-white pb-px hover:gap-4 transition-all duration-200 mt-6 block text-white/70 hover:text-white"
              style="font-family: var(--font-body)"
            >
              Read about the process
              <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M7 1l4 3.5m0 0L7 8m4-3.5H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    @keyframes waveform-idle {
      from { transform: scaleY(0.4); }
      to   { transform: scaleY(1); }
    }
  </style>

  <SiteFooter />
</Base>
