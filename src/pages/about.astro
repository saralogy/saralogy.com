---
import Base from "@layouts/Base.astro";
import "../styles/global.css";
import { Marquee }    from "@components/Marquee";
import { NavHeader }  from "@components/NavHeader";
import { SiteFooter } from "@components/SiteFooter";

const timeline = [
  { year: "2009",      type: "edu",   label: "Valedictorian",                        sub: "Saint Michel French High School · Istanbul" },
  { year: "2009–2014", type: "edu",   label: "B.Sc. Industrial Design",              sub: "Middle East Technical University, Ankara · Exchange: Politecnico di Torino, Italy" },
  { year: "2015–2016", type: "work",  label: "B2B Marketing Specialist",             sub: "ORMA Chipwood · Istanbul · Mar 2015 – Mar 2016" },
  { year: "2016–2018", type: "work",  label: "Brand Store Development Manager",      sub: "Samsung Electronics · Istanbul" },
  { year: "2016–2018", type: "edu",   label: "M.A. Marketing Communications",        sub: "Istanbul Bilgi University · GPA 3.68 · Thesis: IMC in Consumer Electronics" },
  { year: "2018–2020", type: "work",  label: "Digital Marketing Specialist",         sub: "Samsung Electronics · Istanbul · 3× Kristal Elma 2019" },
  { year: "2020–2021", type: "work",  label: "Digital Marketing Manager",            sub: "BSH / Profilo · Istanbul → promoted to Munich HQ after 9 months" },
  { year: "2021–2024", type: "work",  label: "Global Brand Communications Manager",  sub: "BSH / Siemens · Munich · Promoted 2023 · Ended via company restructuring" },
  { year: "2025–2026", type: "work",  label: "IMC Manager, EU",                      sub: "VeSync GmbH (COSORI · Levoit) · Hamburg · Nov 2025 – May 2026" },
  { year: "2026–now",  type: "build", label: "Building vision-intelligence",         sub: "AI marketing infrastructure for SMEs · Hamburg" },
];
---

<Base
  title="About Berk Saraloglu — Marketing Leader & AI Tool Builder"
  description="Turkish-German marketing leader in Hamburg. 11+ years at Samsung, BSH Siemens, VeSync. Building AI-native marketing tools for European SMEs. Industrial Design background. Indie songwriter."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "ProfilePage",
        "@id": "https://saralogy.com/about#profilepage",
        "url": "https://saralogy.com/about",
        "name": "About Berk Saraloglu",
        "mainEntity": { "@id": "https://saralogy.com/#person" }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://saralogy.com" },
          { "@type": "ListItem", "position": 2, "name": "About", "item": "https://saralogy.com/about" }
        ]
      }
    ]
  })} />
  <Marquee client:load />
  <NavHeader client:load />

  <main>

    <!-- Hero -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-20 pb-16">
        <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr] gap-12 md:gap-24 items-end">
          <div>
            <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-4" style="font-family: var(--font-body)">
              ✦ Hamburg, Germany
            </span>
            <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(3.5rem, 8vw, 7rem); line-height: 0.92; letter-spacing: -0.03em;">
              Berk<br />Saraloglu.
            </h1>
          </div>

          <div class="flex flex-col gap-6 pb-2">
            <!-- Photo -->
            <img
              src="/images/berk-profile-2026.png"
              alt="Berk Saraloglu"
              class="w-24 h-24 object-cover border border-border shrink-0"
            />

            <p class="text-sm text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              I spent 11 years inside three of the world's largest consumer electronics companies
              building what the marketing function should look like. The same structural gaps
              kept appearing at every scale. So I started building the infrastructure to fix them.
            </p>

            <div class="flex flex-wrap gap-x-8 gap-y-2">
              {[
                ["English", "C1 · Fluent"],
                ["Turkish", "Native"],
                ["French",  "B2 · Conversational"],
                ["German",  "B1 · Intermediate"],
              ].map(([lang, level]) => (
                <div class="flex items-baseline gap-2">
                  <span class="text-[12px] font-medium text-foreground" style="font-family: var(--font-body)">{lang}</span>
                  <span class="text-[11px] text-muted-foreground" style="font-family: var(--font-body)">{level}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The story -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-16" style="font-family: var(--font-body)">
          ✦ The story
        </span>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border">
          <div class="bg-background p-10 flex flex-col gap-6">
            <span class="text-[11px] tracking-widest text-muted-foreground uppercase" style="font-family: var(--font-body)">01 — The foundation</span>
            <h2 style="font-family: var(--font-display); font-weight: 600; font-size: clamp(1.2rem, 2vw, 1.5rem); letter-spacing: -0.02em; line-height: 1.2;">
              Industrial Design first.
            </h2>
            <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              METU and Politecnico di Torino didn't teach me marketing. They taught me to ask
              why a person would pick up an object before deciding what the object should look like.
              That instinct — user first, surface last — is the thing I've never been able to switch off.
              It's why I brief agencies differently, why I audit customer journeys before touching
              a campaign, and why I build tools before I theorise about them.
            </p>
          </div>

          <div class="bg-background p-10 flex flex-col gap-6">
            <span class="text-[11px] tracking-widest text-muted-foreground uppercase" style="font-family: var(--font-body)">02 — The pattern</span>
            <h2 style="font-family: var(--font-display); font-weight: 600; font-size: clamp(1.2rem, 2vw, 1.5rem); letter-spacing: -0.02em; line-height: 1.2;">
              The same gap, every time.
            </h2>
            <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              At Samsung, BSH, and VeSync the brief was always different. The structural gap
              was always the same: campaigns built faster than the infrastructure could support them.
              No unified customer data. No content system that survived beyond the agency relationship.
              No way to measure what actually moved qualified demand. I rebuilt it at every stop —
              a 22-module IMC operating system at VeSync, a global CRM and content architecture
              at Siemens spanning 20+ countries, a pandemic-era digital turnaround at Profilo
              that tripled online revenue YoY and earned a promotion to Munich HQ in 9 months,
              and a localized conversion engine at Samsung that lowered CAC by 22%.
            </p>
          </div>

          <div class="bg-background p-10 flex flex-col gap-6">
            <span class="text-[11px] tracking-widest text-muted-foreground uppercase" style="font-family: var(--font-body)">03 — Why now</span>
            <h2 style="font-family: var(--font-display); font-weight: 600; font-size: clamp(1.2rem, 2vw, 1.5rem); letter-spacing: -0.02em; line-height: 1.2;">
              AI changes the math.
            </h2>
            <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              A three-person marketing team can now run the intelligence layer that used to require
              twenty. The gap I kept rebuilding inside large companies can be productised for the
              SMEs that never had the budget to fix it properly. I'm building that infrastructure —
              and staying available as a senior marketing leader for the companies that want
              someone who has already done it at scale.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-16">
          <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;">
            Timeline.
          </h2>
          <a href="/career" class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase border-b border-foreground pb-px hover:gap-4 transition-all duration-200" style="font-family: var(--font-body)">
            Full case studies
            <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M7 1l4 3.5m0 0L7 8m4-3.5H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
          </a>
        </div>

        <div class="flex flex-col divide-y divide-border">
          {timeline.map((item) => (
            <div class="flex flex-col md:flex-row md:items-center gap-3 py-5 group">
              <span class="text-[11px] tracking-widest text-muted-foreground w-24 shrink-0" style="font-family: var(--font-body)">
                {item.year}
              </span>
              <span
                class={`text-[9px] tracking-[0.2em] uppercase px-2 py-0.5 w-fit shrink-0 ${
                  item.type === "edu"   ? "bg-muted text-muted-foreground" :
                  item.type === "build" ? "bg-foreground text-background" :
                                         "border border-border text-muted-foreground"
                }`}
                style="font-family: var(--font-body)"
              >
                {item.type === "edu" ? "Education" : item.type === "build" ? "Building" : "Work"}
              </span>
              <div class="flex-1 flex flex-col md:flex-row md:items-center md:justify-between gap-1 md:gap-8">
                <p style="font-family: var(--font-display); font-weight: 600; font-size: clamp(0.95rem, 1.5vw, 1.1rem); letter-spacing: -0.01em;" class="group-hover:translate-x-1 transition-transform duration-200">
                  {item.label}
                </p>
                <p class="text-[12px] text-muted-foreground md:text-right" style="font-family: var(--font-body)">
                  {item.sub}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- What I'm building -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-16">
          <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;">
            Building.
          </h2>
          <a href="/projects" class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase border-b border-foreground pb-px hover:gap-4 transition-all duration-200" style="font-family: var(--font-body)">
            All projects
            <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M7 1l4 3.5m0 0L7 8m4-3.5H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border">
          <div class="bg-background p-10 flex flex-col gap-4">
            <div class="flex items-center justify-between">
              <span class="text-[10px] tracking-[0.2em] uppercase border border-border px-2.5 py-1 text-muted-foreground" style="font-family: var(--font-body)">MVP</span>
              <span class="text-[11px] text-muted-foreground" style="font-family: var(--font-body)">2026</span>
            </div>
            <p style="font-family: var(--font-display); font-weight: 600; font-size: 1.2rem; letter-spacing: -0.01em;">vision-intelligence</p>
            <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              The gap I kept rebuilding at BSH and VeSync — a unified content and campaign intelligence layer —
              made into a product for SMEs that can't afford an enterprise marketing stack.
              The same infrastructure, a fraction of the cost.
            </p>
            <a href="/projects/vision-intelligence" class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase border-b border-foreground pb-px hover:gap-4 transition-all duration-200 mt-auto pt-4 w-fit" style="font-family: var(--font-body)">
              Details
              <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M7 1l4 3.5m0 0L7 8m4-3.5H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
            </a>
          </div>
          <div class="bg-background p-10 flex flex-col gap-4">
            <div class="flex items-center justify-between">
              <span class="text-[10px] tracking-[0.2em] uppercase border border-border px-2.5 py-1 text-muted-foreground" style="font-family: var(--font-body)">Live</span>
              <span class="text-[11px] text-muted-foreground" style="font-family: var(--font-body)">2026</span>
            </div>
            <p style="font-family: var(--font-display); font-weight: 600; font-size: 1.2rem; letter-spacing: -0.01em;">resume-matcher</p>
            <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              Built while navigating my own job search in Germany. ATS optimisation that reflects
              how German hiring systems actually work — not a generic keyword tool, but a
              market-specific matching engine I built and used myself.
            </p>
            <a href="/projects/resume-matcher" class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase border-b border-foreground pb-px hover:gap-4 transition-all duration-200 mt-auto pt-4 w-fit" style="font-family: var(--font-body)">
              Details
              <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M7 1l4 3.5m0 0L7 8m4-3.5H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- The person -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-16" style="font-family: var(--font-body)">
          ✦ Outside the brief
        </span>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border">
          <div class="bg-background p-8 flex flex-col gap-3">
            <p style="font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; letter-spacing: -0.01em;">Music</p>
            <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              Indie songwriter. Writing about movement — physical, creative, professional.
              It feeds back into how I think about brand: both require knowing what a person
              actually feels before they can name it.
            </p>
            <a href="/music" class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase border-b border-foreground pb-px hover:gap-4 transition-all duration-200 w-fit mt-2" style="font-family: var(--font-body)">
              Listen
              <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M7 1l4 3.5m0 0L7 8m4-3.5H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
            </a>
          </div>
          <div class="bg-background p-8 flex flex-col gap-3">
            <p style="font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; letter-spacing: -0.01em;">Hamburg</p>
            <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              Based here since late 2024. Not relocating before mid-2027 — family roots, my partner's
              professional certification process, and a wedding in September 2026 all tie me here.
              Hamburg is the base; Europe is the market.
            </p>
          </div>
          <div class="bg-background p-8 flex flex-col gap-3">
            <p style="font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; letter-spacing: -0.01em;">Background</p>
            <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              Turkish. Grew up in Istanbul, studied in Ankara and Turin, moved to Munich for BSH,
              then Düsseldorf for VeSync, now Hamburg. The pattern of moving for the right role
              is well established — just not outside Germany for now.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-foreground text-background">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <p style="font-family: var(--font-display); font-weight: 700; font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1; letter-spacing: -0.02em;">
          Available for the<br /><span class="italic font-light">right role in Hamburg.</span>
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/work" class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase bg-white text-black px-6 py-3 hover:bg-white/90 transition-opacity" style="font-family: var(--font-body)">
            Work with me
          </a>
          <a href="mailto:berksaraloglu@gmail.com?subject=via%20saralogy.com" class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase px-6 py-3 text-white/50 hover:text-white transition-colors duration-200" style="font-family: var(--font-body)">
            Email directly ↗
          </a>
        </div>
      </div>
    </section>

  </main>

  <SiteFooter />
</Base>
