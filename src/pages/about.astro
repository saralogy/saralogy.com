---
import Base from "@layouts/Base.astro";
import "../styles/global.css";
import { Marquee }    from "@components/Marquee";
import { NavHeader }  from "@components/NavHeader";
import { SiteFooter } from "@components/SiteFooter";

const career = [
  { company: "VeSync GmbH", role: "Integrated Marketing Manager, EU", period: "Nov 2025 – May 2026", location: "Düsseldorf", outcome: "117% of launch target in 53 days across 8 channels.", slug: "vesync" },
  { company: "BSH / Siemens Global", role: "Senior Brand Communications Manager", period: "May 2020 – Nov 2024", location: "Munich", outcome: "Built Siemens' first global Instagram presence. €M+ organic media value across 10+ markets.", slug: "bsh" },
  { company: "Samsung Electronics", role: "Digital Marketing Specialist", period: "Apr 2016 – May 2020", location: "Istanbul", outcome: "3× Kristal Elma Awards. YouTube format adopted as Samsung EMEA benchmark.", slug: "samsung" },
  { company: "ORMA Chipwood", role: "B2B Marketing Specialist", period: "Apr 2015 – Apr 2016", location: "Istanbul", outcome: "Built architect/designer segment from zero. Full website and app redesign.", slug: "orma" },
];

const lenses = [
  { title: "Industrial Design", body: "METU and Politecnico di Torino trained me to start from human behaviour, prototype quickly, and treat constraints as design material." },
  { title: "Marketing Systems", body: "Samsung, BSH, and VeSync taught me that the visible campaign is only the last layer. The operating system underneath decides whether it scales." },
  { title: "Music", body: "Songwriting keeps the emotional muscle alive. Tension, timing, memory, and the courage to remove what is unnecessary." },
];
---

<Base
  title="About Berk Saraloglu — Marketing Leader & AI Tool Builder"
  description="Turkish-German marketing leader in Hamburg. 11+ years at Samsung, BSH Siemens, VeSync. Building AI-native marketing tools for DACH SMEs. Industrial Design background. Indie songwriter."
>
  <Marquee client:load />
  <NavHeader client:load />

  <main>
    <!-- Hero -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-20 pb-14">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-10">
          <div>
            <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-3" style="font-family: var(--font-body)">
              ✦ Hamburg, Germany
            </span>
            <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(3rem, 7vw, 6rem); line-height: 0.95; letter-spacing: -0.03em;">
              Berk<br />Saraloglu.
            </h1>
          </div>
          <div class="flex flex-col gap-6 max-w-sm">
            <p class="text-sm text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              I started in Industrial Design, moved into marketing, and kept the designer's habit: understand the system before changing the surface. That's how I build campaigns, teams, AI workflows, and songs.
            </p>
            <div class="flex flex-wrap gap-2">
              {["Hamburg", "DACH Market", "AI Marketing", "Product Launches", "Industrial Design", "Songwriter"].map((tag) => (
                <span class="text-[10px] tracking-[0.15em] uppercase border border-border px-3 py-1.5 text-muted-foreground" style="font-family: var(--font-body)">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Three lenses -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-12" style="font-family: var(--font-body)">
          ✦ The lens
        </span>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border">
          {lenses.map(({ title, body }, i) => (
            <div class="bg-background p-8 flex flex-col gap-4">
              <span class="text-[11px] tracking-widest text-muted-foreground" style="font-family: var(--font-body)">{String(i + 1).padStart(2, "0")}</span>
              <h2 style="font-family: var(--font-display); font-weight: 600; font-size: clamp(1.2rem, 2vw, 1.6rem); letter-spacing: -0.02em; line-height: 1.1;">
                {title}
              </h2>
              <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Career summary -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12">
          <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;">
            Career.
          </h2>
          <a href="/career" class="text-[11px] tracking-widest uppercase border-b border-foreground pb-px hover:gap-4 transition-all duration-200 inline-flex items-center gap-2" style="font-family: var(--font-body)">
            Full case studies
            <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M7 1l4 3.5m0 0L7 8m4-3.5H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
          </a>
        </div>

        <div class="flex flex-col divide-y divide-border">
          {career.map((t, i) => (
            <a href={`/career/${t.slug}`} class="group flex flex-col md:flex-row md:items-center gap-4 py-6 hover:bg-card transition-colors duration-150">
              <span class="text-[11px] tracking-widest text-muted-foreground w-10 shrink-0" style="font-family: var(--font-body)">{String(i + 1).padStart(2, "0")}</span>
              <div class="md:w-1/3">
                <p style="font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; letter-spacing: -0.01em;" class="group-hover:translate-x-1 transition-transform duration-200">{t.company}</p>
                <p class="text-[12px] text-muted-foreground mt-0.5" style="font-family: var(--font-body)">{t.role} · {t.period}</p>
              </div>
              <p class="md:w-1/2 text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{t.outcome}</p>
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="md:ml-auto text-muted-foreground group-hover:text-foreground group-hover:translate-x-1 transition-all duration-200 shrink-0">
                <path d="M3 9h12M10 4l5 5-5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Currently building -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12">
          <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;">
            Building.
          </h2>
          <a href="/projects" class="text-[11px] tracking-widest uppercase border-b border-foreground pb-px hover:gap-4 transition-all duration-200 inline-flex items-center gap-2" style="font-family: var(--font-body)">
            All projects
            <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M7 1l4 3.5m0 0L7 8m4-3.5H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border">
          {[
            { slug: "vision-intelligence", label: "MVP", title: "vision-intelligence", desc: "AI marketing platform for DACH SMEs. The gap I identified at BSH and VeSync, made into a product." },
            { slug: "resume-matcher", label: "Live", title: "resume-matcher", desc: "ATS optimisation for job seekers in Germany. Built from personal experience navigating the DACH job market." },
          ].map(({ slug, label, title, desc }) => (
            <a href={`/projects/${slug}`} class="group bg-background p-8 flex flex-col gap-4 hover:bg-card transition-colors duration-200">
              <span class="text-[10px] tracking-[0.2em] uppercase border border-border px-2.5 py-1 w-fit text-muted-foreground" style="font-family: var(--font-body)">{label}</span>
              <p style="font-family: var(--font-display); font-weight: 600; font-size: 1.2rem; letter-spacing: -0.01em;" class="group-hover:translate-x-1 transition-transform duration-200">{title}</p>
              <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;" class="mb-12">
          Education.
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border">
          {[
            { degree: "M.A. Marketing Communication", school: "Istanbul Bilgi University", year: "2016–2018", note: "Built the strategic layer on top of a design foundation." },
            { degree: "B.Sc. Industrial Design", school: "Middle East Technical University", year: "2009–2014", note: "Exchange: Politecnico di Torino. Designed for human behaviour before attention." },
          ].map(({ degree, school, year, note }) => (
            <div class="bg-background p-8 flex flex-col gap-3">
              <span class="text-[11px] tracking-widest uppercase text-muted-foreground" style="font-family: var(--font-body)">{year}</span>
              <p style="font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; letter-spacing: -0.01em;">{degree}</p>
              <p class="text-[12px] text-muted-foreground" style="font-family: var(--font-body)">{school}</p>
              <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{note}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-foreground text-background">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <p style="font-family: var(--font-display); font-weight: 700; font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1; letter-spacing: -0.02em;">
          Available for the<br /><span class="italic font-light">right role in Hamburg.</span>
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/work" class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase border border-white/30 px-6 py-3 hover:bg-white hover:text-black transition-all duration-200" style="font-family: var(--font-body)">
            Work with me
          </a>
          <a href="mailto:berksaraloglu@gmail.com?subject=via%20saralogy.com" class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase px-6 py-3 text-white/50 hover:text-white transition-colors duration-200" style="font-family: var(--font-body)">
            Email directly ↗
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Base>
