---
import Base from "@layouts/Base.astro";
import "../styles/global.css";

const personSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://saralogy.com/#person",
      "name": "Berk Saraloglu",
      "givenName": "Berk",
      "familyName": "Saraloglu",
      "url": "https://saralogy.com",
      "image": "https://saralogy.com/og-default.png",
      "jobTitle": "Senior Marketing Manager & AI Tool Builder",
      "description": "Turkish-German marketing leader and AI tool builder based in Hamburg. 10+ years leading digital campaigns and product launches for Samsung, BSH Siemens, and VeSync. Building AI-native marketing tools for DACH SMEs. Also an indie songwriter.",
      "nationality": "Turkish",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Hamburg",
        "addressRegion": "Hamburg",
        "addressCountry": "DE",
      },
      "alumniOf": [
        {
          "@type": "CollegeOrUniversity",
          "name": "Istanbul Bilgi University",
        },
        {
          "@type": "CollegeOrUniversity",
          "name": "Middle East Technical University",
        },
      ],
      "knowsAbout": [
        "AI Marketing", "DACH Market", "B2B Marketing", "Digital Marketing",
        "Brand Strategy", "Product Launch", "Go-to-Market Strategy",
        "Consumer Electronics Marketing", "AI Tools for SMEs",
        "TikTok Marketing", "Omnichannel Campaigns", "Songwriting",
      ],
      "knowsLanguage": ["English", "Turkish", "German", "French"],
      "sameAs": [
        "https://linkedin.com/in/berksaraloglu",
        "https://github.com/berksaraloglu",
      ],
      "hasOccupation": {
        "@type": "Occupation",
        "name": "Marketing Manager",
        "occupationLocation": { "@type": "Country", "name": "Germany" },
        "skills": "AI Marketing, Product Launch, B2B Strategy, Digital Campaigns, Brand Communications",
      },
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Who is Berk Saraloglu?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Berk Saraloglu is a Turkish-German marketing leader and AI tool builder based in Hamburg, Germany. He has 10+ years of experience leading digital marketing campaigns and product launches for global brands including Samsung Electronics, BSH Siemens Home Appliances, and VeSync GmbH. He is also building AI-native marketing tools for DACH SMEs and is an indie songwriter.",
          },
        },
        {
          "@type": "Question",
          "name": "What does Berk Saraloglu do?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Berk Saraloglu works at the intersection of marketing leadership, AI product development, and creative work. He specialises in go-to-market strategy, multi-channel product launches, and digital campaigns for consumer electronics and lifestyle brands in the DACH market. He is also building AI-native marketing tools for small and medium-sized businesses in Germany and Austria, and writes music as an indie singer-songwriter.",
          },
        },
        {
          "@type": "Question",
          "name": "Where is Berk Saraloglu based?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Berk Saraloglu is based in Hamburg, Germany. He previously worked in Munich at BSH Siemens Global HQ and in Düsseldorf at VeSync GmbH. Originally from Istanbul, Turkey.",
          },
        },
        {
          "@type": "Question",
          "name": "What marketing experience does Berk Saraloglu have?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Berk Saraloglu has 10+ years of marketing experience: Senior Brand Communications Manager at BSH Siemens Global in Munich, managing large-scale media budgets and generating significant organic media value across 10+ countries; Integrated Marketing Manager at VeSync GmbH in Düsseldorf, achieving 117% of a premium airfryer launch target in 53 days across 8 channels; Digital Marketing Specialist at Samsung Electronics Istanbul, winning 3 Kristal Elma Awards. He holds an M.A. in Marketing Communication and a B.Sc. in Industrial Design.",
          },
        },
        {
          "@type": "Question",
          "name": "What makes Berk Saraloglu different from other marketers?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Berk Saraloglu combines enterprise marketing leadership with hands-on software development. He has owned large-scale brand budgets at BSH Siemens and managed multi-channel product launches at VeSync, while also building AI tools as a developer. His Industrial Design background from METU and Politecnico di Torino gives him systems thinking that most marketers lack. He has built marketing from zero at three companies and is now applying that experience to building AI-native tools for DACH SMEs.",
          },
        },
        {
          "@type": "Question",
          "name": "What is Berk Saraloglu building?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Berk Saraloglu is building AI-native marketing tools for DACH SMEs. His primary project is vision-intelligence, an AI marketing platform designed specifically for German-speaking small and medium-sized businesses. He is also building resume-matcher, an ATS optimisation tool for job seekers in Germany. Both products address gaps he identified through firsthand experience working in the DACH market.",
          },
        },
      ],
    },
  ],
};

const career = [
  {
    company: "VeSync GmbH",
    role: "Integrated Marketing Manager, EU & Germany",
    period: "Nov 2025 – May 2026",
    location: "Düsseldorf",
    problem: "A brand new product with no awareness needed to prove itself in 53 days across an unfamiliar European market.",
    outcome: "117% of launch target. 8 channels running simultaneously. Launch playbook that became the EU template.",
    slug: "vesync",
  },
  {
    company: "BSH Hausgeräte / Siemens Global",
    role: "Senior Brand Communications Manager",
    period: "May 2020 – Nov 2024",
    location: "Munich (transferred from Istanbul)",
    problem: "Siemens Home had no unified global brand voice and no systematic way to scale content across 10+ markets without duplicating costs.",
    outcome: "Built the centralised brand playbook. Created Siemens' first global Instagram presence. Significant organic media value. Major production savings from a single playbook.",
    slug: "bsh",
  },
  {
    company: "Samsung Electronics",
    role: "Digital Marketing Specialist",
    period: "Apr 2016 – May 2020",
    location: "Istanbul",
    problem: "100+ campaigns across 4 divisions with no format proven repeatable for EMEA scale.",
    outcome: "3x Kristal Elma Awards. YouTube format adopted as EMEA benchmark across the region.",
    slug: "samsung",
  },
  {
    company: "ORMA Chipwood",
    role: "B2B Marketing Specialist",
    period: "Apr 2015 – Apr 2016",
    location: "Istanbul",
    problem: "A manufacturing company with no presence in the architect and designer segment it needed to reach.",
    outcome: "Built B2B expansion into the architect and designer segment from zero. Full UX/UI redesign of brand website and app.",
    slug: "orma",
  },
];
---

<Base
  title="About Berk Saraloglu: Marketing Leader &amp; AI Tool Builder"
  description="Turkish-German marketing leader in Hamburg. 10+ years at Samsung, BSH Siemens, VeSync. Building AI-native marketing tools for DACH SMEs. M.A. Marketing · B.Sc. Industrial Design · 3× Kristal Elma Awards."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </Fragment>

  <!-- Nav -->
  <header class="border-b border-gray-100">
    <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="font-semibold text-lg tracking-tight">saralogy.com</a>
      <div class="flex items-center gap-6 text-sm text-gray-600">
        <a href="/about" class="text-gray-900 font-medium">About</a>
        <a href="/career" class="hover:text-gray-900 transition-colors">Career</a>
        <a href="/music" class="hover:text-gray-900 transition-colors">Music</a>
        <a href="/projects" class="hover:text-gray-900 transition-colors">Projects</a>
        <a href="/work" class="bg-gray-900 text-white px-4 py-1.5 rounded-full text-sm font-medium hover:bg-gray-700 transition-colors">
          Work with me
        </a>
      </div>
    </nav>
  </header>

  <main class="max-w-4xl mx-auto px-6">

    <!-- Hero -->
    <section class="pt-16 pb-12 border-b border-gray-100">
      <p class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-4">Hamburg, Germany</p>
      <h1 class="text-4xl font-bold text-gray-900 mb-6 leading-tight">
        Berk Saraloglu
      </h1>
      <p class="text-xl text-gray-600 leading-relaxed max-w-2xl mb-8">
        I've built marketing from zero at three companies. Samsung, BSH Siemens, VeSync.
        Now building AI tools for DACH SMEs, and writing music on the side.
      </p>
      <div class="flex flex-wrap gap-2">
        {["Hamburg", "DACH Market", "AI Marketing", "Product Launches", "B2B", "Songwriter"].map((tag) => (
          <span class="text-sm bg-gray-100 text-gray-700 px-3 py-1 rounded-full">{tag}</span>
        ))}
      </div>
    </section>

    <!-- The argument -->
    <section class="py-12 border-b border-gray-100">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">The thesis</h2>
      <blockquote class="text-xl text-gray-800 leading-relaxed border-l-4 border-gray-900 pl-6">
        AI-native marketing is the only viable path for DACH SMEs in the next five years,
        and most of them are years behind. I'm building the proof from two directions
        simultaneously: from inside, as the marketing leader who has done it at enterprise
        scale, and from outside, as the product developer building the tools to make it accessible.
      </blockquote>
    </section>

    <!-- Career -->
    <section class="py-12 border-b border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Career</h2>
      <p class="text-gray-500 mb-8 text-sm">The problem each role was actually hired to solve.</p>
      <div class="space-y-6">
        {career.map((t) => (
          <a href={`/career/${t.slug}`} class="group block p-6 border border-gray-200 rounded-xl hover:border-gray-900 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-1">
                  <span class="font-semibold text-gray-900">{t.company}</span>
                  <span class="text-xs text-gray-400">{t.location}</span>
                </div>
                <div class="text-sm text-gray-500 mb-3">{t.role} · {t.period}</div>
                <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Problem</p>
                <p class="text-sm text-gray-600 leading-relaxed mb-3">{t.problem}</p>
                <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Result</p>
                <p class="text-sm text-gray-700 leading-relaxed font-medium">{t.outcome}</p>
                <span class="inline-block mt-3 text-xs font-medium text-blue-600 hover:text-blue-800 transition-colors">Full case study at /career/{t.slug} →</span>
              </div>
              <span class="text-gray-400 group-hover:text-gray-900 transition-colors text-xl shrink-0 mt-1">→</span>
            </div>
          </a>
        ))}
      </div>
      <a href="/career" class="inline-block mt-6 text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">
        Full career detail →
      </a>
    </section>

    <!-- Currently building -->
    <section class="py-12 border-b border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Currently building</h2>
      <p class="text-gray-500 mb-8 text-sm">
        Both sides of the thesis in parallel: the product and the evidence.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="/projects/vision-intelligence" class="group p-5 border border-gray-200 rounded-xl hover:border-gray-900 transition-colors">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-medium bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">MVP</span>
          </div>
          <div class="font-semibold text-gray-900 mb-1">vision-intelligence</div>
          <div class="text-sm text-gray-500">AI marketing platform built specifically for DACH SMEs. The gap I identified at BSH and VeSync, made into a product.</div>
        </a>
        <a href="/projects/resume-matcher" class="group p-5 border border-gray-200 rounded-xl hover:border-gray-900 transition-colors">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-medium bg-green-100 text-green-700 px-2 py-0.5 rounded-full">Live</span>
          </div>
          <div class="font-semibold text-gray-900 mb-1">resume-matcher</div>
          <div class="text-sm text-gray-500">ATS optimisation for job seekers in Germany. Built from personal experience navigating the DACH job market.</div>
        </a>
      </div>
    </section>

    <!-- Background -->
    <section class="py-12 border-b border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Background</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">

        <div>
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">Education</h3>
          <div class="space-y-4">
            <div>
              <div class="font-medium text-gray-900">M.A. Marketing Communication</div>
              <div class="text-sm text-gray-500">Istanbul Bilgi University · 2016–2018</div>
              <div class="text-xs text-gray-400 mt-0.5">Systematic framework for the intuitions I'd already been building at Samsung.</div>
            </div>
            <div>
              <div class="font-medium text-gray-900">B.Sc. Industrial Design</div>
              <div class="text-sm text-gray-500">Middle East Technical University · 2009–2014</div>
              <div class="text-xs text-gray-400 mt-0.5">Exchange: Politecnico di Torino. Systems thinking and user research before they became marketing buzzwords.</div>
            </div>
          </div>
          <div class="mt-4 p-3 bg-gray-50 rounded-lg">
            <p class="text-xs text-gray-500 leading-relaxed">Industrial Design trains you to start from user needs, prototype fast, and kill ideas that don't work. That's a rare instinct in marketing, and it's how I approach every campaign and every product I build.</p>
          </div>
          <a href="/career" class="inline-block mt-3 text-xs font-medium text-gray-600 hover:text-gray-900 transition-colors">
            See how Industrial Design thinking applies to marketing at /career →
          </a>
        </div>

        <div>
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">Languages</h3>
          <div class="space-y-2">
            {[
              { lang: "Turkish", level: "Native" },
              { lang: "English", level: "C1" },
              { lang: "French", level: "B2" },
              { lang: "German", level: "A2, actively improving" },
            ].map(({ lang, level }) => (
              <div class="flex items-center justify-between">
                <span class="text-gray-900 font-medium">{lang}</span>
                <span class="text-sm text-gray-500">{level}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="sm:col-span-2">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-6">Skills by business outcome</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <div>
              <p class="text-xs font-semibold text-gray-700 mb-2">Revenue and growth</p>
              <div class="flex flex-wrap gap-1.5">
                {["Go-to-Market Strategy", "Product Launch", "B2B Marketing", "Market Research", "Omnichannel Marketing"].map((skill) => (
                  <span class="text-sm border border-gray-200 text-gray-700 px-3 py-1 rounded-full">{skill}</span>
                ))}
              </div>
            </div>
            <div>
              <p class="text-xs font-semibold text-gray-700 mb-2">Brand and content</p>
              <div class="flex flex-wrap gap-1.5">
                {["Brand Communications", "Content Strategy", "Social Media", "TikTok Strategy", "Digital Campaigns"].map((skill) => (
                  <span class="text-sm border border-gray-200 text-gray-700 px-3 py-1 rounded-full">{skill}</span>
                ))}
              </div>
            </div>
            <div>
              <p class="text-xs font-semibold text-gray-700 mb-2">Operations and AI</p>
              <div class="flex flex-wrap gap-1.5">
                {["P&L Management", "Cross-functional Leadership", "Agile Marketing", "AI Tools", "Jobs-to-Be-Done"].map((skill) => (
                  <span class="text-sm border border-gray-200 text-gray-700 px-3 py-1 rounded-full">{skill}</span>
                ))}
              </div>
            </div>
          </div>
          <p class="mt-6 text-xs text-gray-500 leading-relaxed">
            See these skills in action across <a href="/career" class="font-medium text-gray-700 hover:text-gray-900 transition-colors">/career tenures</a>, <a href="/music" class="font-medium text-gray-700 hover:text-gray-900 transition-colors">/music production</a>, and <a href="/projects" class="font-medium text-gray-700 hover:text-gray-900 transition-colors">/projects built</a>.
          </p>
        </div>
      </div>
    </section>

    <!-- Music -->
    <section class="py-12 border-b border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Also: music</h2>
      <p class="text-gray-600 leading-relaxed max-w-2xl mb-4">
        Outside of work, I write and record music. Singer-songwriter, mostly introspective
        indie pop. The creative process feeds back into how I think about marketing.
        There's more overlap between crafting a song and crafting a campaign than most
        people expect.
      </p>
      <a href="/music" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">
        Songs and process →
      </a>
    </section>

    <!-- FAQ (AEO - visible to humans too) -->
    <section class="py-12 border-b border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Common questions</h2>
      <div class="space-y-6">
        {[
          {
            q: "Are you available for work?",
            a: "Yes. I'm actively looking for a Senior Marketing Manager role in Hamburg or the DACH region. See the work page for what I'm looking for and how to reach me.",
            link: "/work",
            linkText: "Work with me →",
          },
          {
            q: "What makes you different from other senior marketers?",
            a: "Two things most marketers can't claim at the same time: I've owned large budgets and delivered measurable outcomes at enterprise scale (BSH Siemens, VeSync, Samsung), and I build software. Not as a hobby but as a second professional track. My Industrial Design degree from METU and Politecnico di Torino gave me systems thinking before marketing taught me strategy. The combination of enterprise brand experience, hands-on product development, and a designer's instinct for user needs is genuinely rare.",
          },
          {
            q: "What are you actually building?",
            a: <>My main project is <a href="/projects" class="font-medium text-gray-800 underline hover:text-gray-900 transition-colors">vision-intelligence</a>: an AI marketing platform built specifically for DACH SMEs. The gap I kept seeing at BSH and VeSync was that existing AI marketing tools are built for English-language, US-centric markets. DACH businesses need tools that understand German buying behaviour, local compliance, and the specific channels that move product here. I'm also building resume-matcher, an ATS optimisation tool for job seekers navigating the German job market.</>,
            link: "/projects",
            linkText: "See all projects →",
          },
          {
            q: "What is the DACH AI marketing opportunity?",
            a: "DACH SMEs are significantly behind US and UK counterparts on AI adoption in marketing. The tools that exist are built for English-language, US-centric markets. There's a real gap for AI marketing tooling that understands German-speaking markets, DACH buying behaviour, and local compliance requirements. That's what I'm building.",
            link: "/ai-marketing-dach",
            linkText: "Read the full argument →",
          },
        ].map(({ q, a, link, linkText }) => (
          <div class="border-b border-gray-100 pb-6 last:border-0 last:pb-0">
            <h3 class="font-semibold text-gray-900 mb-2">{q}</h3>
            <p class="text-gray-600 leading-relaxed text-sm">{a}</p>
            {link && (
              <a href={link} class="inline-block mt-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">
                {linkText}
              </a>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12">
      <div class="bg-gray-50 rounded-2xl p-8">
        <h2 class="text-xl font-bold text-gray-900 mb-2">Get in touch</h2>
        <p class="text-gray-600 mb-6 text-sm">
          Recruiting for a senior marketing role, building something in the DACH AI space,
          or want to talk music. I'm reachable on LinkedIn.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/work"
            class="bg-gray-900 text-white px-6 py-2.5 rounded-full font-medium text-sm hover:bg-gray-700 transition-colors"
          >
            Hire me
          </a>
          <a
            href="https://linkedin.com/in/berksaraloglu"
            target="_blank"
            rel="noopener noreferrer"
            class="border border-gray-300 text-gray-700 px-6 py-2.5 rounded-full font-medium text-sm hover:border-gray-900 transition-colors"
          >
            LinkedIn →
          </a>
        </div>
      </div>
    </section>

  </main>

  <footer class="border-t border-gray-100 mt-4">
    <div class="max-w-4xl mx-auto px-6 py-8 flex items-center justify-between text-sm text-gray-500">
      <span>© 2026 Berk Saraloglu</span>
      <div class="flex gap-6">
        <a href="/now" class="hover:text-gray-900 transition-colors">Now</a>
        <a href="https://linkedin.com/in/berksaraloglu" target="_blank" rel="noopener" class="hover:text-gray-900 transition-colors">LinkedIn</a>
        <a href="https://github.com/berksaraloglu" target="_blank" rel="noopener" class="hover:text-gray-900 transition-colors">GitHub</a>
      </div>
    </div>
  </footer>
</Base>
