---
import Base from "@layouts/Base.astro";
import "../styles/global.css";
import { Marquee }    from "@components/Marquee";
import { NavHeader }  from "@components/NavHeader";
import { SiteFooter } from "@components/SiteFooter";
---

<Base
  title="AI Marketing Consulting for DACH SMEs | Berk Saraloglu"
  description="Fixed-scope AI marketing consulting for DACH companies with 10–100 employees. AI transformation audits and product launch strategy. Hamburg-based, available now."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "ProfessionalService",
        "@id": "https://saralogy.com/work#service",
        "name": "AI Marketing Consulting by Berk Saraloglu",
        "description": "AI marketing transformation and product launch strategy consulting for DACH SMEs.",
        "url": "https://saralogy.com/work",
        "provider": { "@id": "https://saralogy.com/#person" },
        "areaServed": { "@type": "Country", "name": "DE" },
        "serviceType": "Marketing Consulting",
        "availableLanguage": ["en", "tr"]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://saralogy.com" },
          { "@type": "ListItem", "position": 2, "name": "Work with Me", "item": "https://saralogy.com/work" }
        ]
      }
    ]
  })} />
  <Marquee client:load />
  <NavHeader client:load />

  <main>
    <!-- Hero -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-20 pb-14">
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-flex items-center gap-2 text-[11px] tracking-[0.2em] uppercase border border-border px-4 py-2" style="font-family: var(--font-body)">
            <span class="w-1.5 h-1.5 bg-foreground rounded-full animate-pulse"></span>
            Available now
          </span>
          <a href="/open-to-work" class="text-[11px] tracking-[0.2em] uppercase text-muted-foreground hover:text-foreground transition-colors duration-200" style="font-family: var(--font-body)">
            Looking for a hire? → /open-to-work
          </a>
        </div>
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-10">
          <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2.5rem, 6vw, 5.5rem); line-height: 0.95; letter-spacing: -0.03em;">
            AI Marketing<br />
            <span class="italic font-light">Transformation</span><br />
            for DACH SMEs.
          </h1>
          <div class="max-w-sm">
            <p class="text-sm text-muted-foreground leading-relaxed mb-6" style="font-family: var(--font-body)">
              Fixed-scope consulting engagements for companies ready to move beyond experimenting with AI tools. 11+ years in marketing, built for the DACH market.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="https://cal.com/saralogy/15min" target="_blank" rel="noopener noreferrer"
                class="text-[11px] tracking-widest uppercase bg-foreground text-background px-5 py-2.5 hover:opacity-80 transition-opacity duration-200"
                style="font-family: var(--font-body)">
                Book a discovery call
              </a>
              <a href="mailto:berksaraloglu@gmail.com?subject=Consulting%20enquiry%20via%20saralogy.com"
                class="text-[11px] tracking-widest uppercase border border-border px-5 py-2.5 hover:border-foreground transition-colors duration-200 text-muted-foreground hover:text-foreground"
                style="font-family: var(--font-body)">
                Email Berk
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Who this is for -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-12" style="font-family: var(--font-body)">✦ Who this is for</span>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-px bg-border">
          {[
            { label: "Location", value: "DACH — Germany, Austria, Switzerland" },
            { label: "Company size", value: "10–100 employees" },
            { label: "Marketing team", value: "Single marketer or small team" },
            { label: "Sector", value: "B2B or B2C consumer products" },
            { label: "Stage", value: "Beyond experimenting with AI" },
            { label: "Readiness", value: "Budget and mandate to move fast" },
          ].map(({ label, value }) => (
            <div class="bg-background p-6 flex flex-col gap-2">
              <span class="text-[10px] tracking-[0.2em] uppercase text-muted-foreground" style="font-family: var(--font-body)">{label}</span>
              <span style="font-family: var(--font-display); font-weight: 600; font-size: 1rem; letter-spacing: -0.01em;">{value}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Offering 1 -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12">
          <div>
            <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-4" style="font-family: var(--font-body)">✦ Offering 01</span>
            <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;">
              AI Marketing<br /><span class="italic font-light">Transformation.</span>
            </h2>
          </div>
          <div class="max-w-xs">
            <p class="text-sm text-muted-foreground leading-relaxed mb-2" style="font-family: var(--font-body)">
              Your team is using AI tools but output is inconsistent and nothing connects to your reporting stack.
            </p>
            <p style="font-family: var(--font-display); font-weight: 600; font-size: 1rem; letter-spacing: -0.01em;">€3,000–6,000 · Phase 1 · Fixed scope</p>
          </div>
        </div>

        <div class="flex flex-col divide-y divide-border">
          {[
            { title: "Current AI tool audit", desc: "Full inventory of what you have, what's working, and what's wasted. Most SMEs are paying for 4–6 tools with 40% overlap and no clear owner." },
            { title: "3 highest-leverage automations identified", desc: "Not a list of everything AI could theoretically do. Three specific automations ranked by implementation effort versus revenue or time impact for your company." },
            { title: "First automation implemented and documented", desc: "One automation goes live during the engagement. Not a proof of concept — a running system with an owner and a monitoring process." },
            { title: "Handoff playbook the team can run independently", desc: "Documentation written for the person who will maintain it, not for a consultant. Includes edge cases, failure modes, and escalation paths." },
          ].map(({ title, desc }, i) => (
            <div class="flex flex-col md:flex-row gap-4 py-8 group">
              <span class="text-[11px] tracking-widest text-muted-foreground w-10 shrink-0 pt-1" style="font-family: var(--font-body)">{String(i + 1).padStart(2, "0")}</span>
              <div class="md:w-1/3 shrink-0">
                <p style="font-family: var(--font-display); font-weight: 600; font-size: clamp(1rem, 1.5vw, 1.2rem); letter-spacing: -0.01em; line-height: 1.2;">{title}</p>
              </div>
              <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{desc}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 border-t border-border pt-8">
          <p class="text-[13px] text-muted-foreground" style="font-family: var(--font-body)">
            <span class="text-foreground font-medium">Timeline:</span> 4–6 weeks, fixed scope. No retainer, no scope creep.
          </p>
        </div>
      </div>
    </section>

    <!-- Offering 2 -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12">
          <div>
            <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-4" style="font-family: var(--font-body)">✦ Offering 02</span>
            <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;">
              Product Launch<br /><span class="italic font-light">Strategy.</span>
            </h2>
          </div>
          <div class="max-w-xs">
            <p class="text-sm text-muted-foreground leading-relaxed mb-2" style="font-family: var(--font-body)">
              You have a product ready for DACH but no structured go-to-market plan. I compress the planning cycle by 30–40%.
            </p>
            <p style="font-family: var(--font-display); font-weight: 600; font-size: 1rem; letter-spacing: -0.01em;">Quote on request · Fixed scope</p>
          </div>
        </div>

        <div class="flex flex-col divide-y divide-border">
          {[
            { title: "Jobs-to-Be-Done customer research brief", desc: "Structured interview guide and synthesis framework. You don't launch into a market you haven't listened to — this becomes the brief every channel strategy references." },
            { title: "Full-funnel channel strategy document", desc: "Channel selection, sequencing, and budget allocation for DACH. Built on what has actually moved product in this market, not generic digital marketing frameworks." },
            { title: "Sell-out target model with channel KPIs", desc: "A model that connects your revenue target to channel-level activity. Gives category managers and retailers something to plan against. Based on the framework I used at VeSync: 117% of sell-out target in 53 days." },
            { title: "Agency and creator briefs ready to send", desc: "Creative briefs, channel briefs, and influencer briefs written to the standard an agency can execute without a month of back-and-forth." },
          ].map(({ title, desc }, i) => (
            <div class="flex flex-col md:flex-row gap-4 py-8 group">
              <span class="text-[11px] tracking-widest text-muted-foreground w-10 shrink-0 pt-1" style="font-family: var(--font-body)">{String(i + 1).padStart(2, "0")}</span>
              <div class="md:w-1/3 shrink-0">
                <p style="font-family: var(--font-display); font-weight: 600; font-size: clamp(1rem, 1.5vw, 1.2rem); letter-spacing: -0.01em; line-height: 1.2;">{title}</p>
              </div>
              <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{desc}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 border-t border-border pt-8">
          <p class="text-[13px] text-muted-foreground" style="font-family: var(--font-body)">
            <span class="text-foreground font-medium">Timeline:</span> 3–4 weeks. Priced per engagement after a scoping call.
          </p>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-12" style="font-family: var(--font-body)">✦ How it works</span>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-px bg-border">
          {[
            { step: "01", title: "Discovery call", desc: "20 minutes. You describe the problem, I ask the questions that matter. No pitch deck." },
            { step: "02", title: "Scope proposal", desc: "Within 48 hours I send a fixed-scope proposal with deliverables, timeline, and price." },
            { step: "03", title: "Fixed engagement", desc: "We work to the agreed scope. No retainer, no scope creep, no surprise invoices." },
            { step: "04", title: "Handoff", desc: "Everything documented. Your team runs it independently after the engagement closes." },
          ].map(({ step, title, desc }) => (
            <div class="bg-background p-8 flex flex-col gap-4">
              <span class="text-[11px] tracking-widest text-muted-foreground" style="font-family: var(--font-body)">{step}</span>
              <p style="font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; letter-spacing: -0.01em;">{title}</p>
              <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Evidence -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12">
          <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;">Commercial<br /><span class="italic font-light">impact.</span></h2>
          <p class="max-w-xs text-sm text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">11+ years. Three enterprise environments. Concrete numbers, not credentials.</p>
        </div>

        <div class="flex flex-col divide-y divide-border">
          {[
            { title: "117% of sell-out target in 53 days", desc: "Full-funnel launch of a premium airfryer at VeSync across 8 channels simultaneously. Aligned category managers, briefed agencies, owned the budget, delivered the post-mortem." },
            { title: "€1.5M annual content cost reduction at BSH", desc: "Restructured content production across 10+ countries while lifting organic reach. Organic media scaled to €M+ equivalent. This is what systematic beats creative looks like." },
            { title: "600% CRM growth at Samsung", desc: "Built the CRM infrastructure and loyalty programmes that scaled the subscriber base. The growth came from architecture decisions, not campaign spend." },
            { title: "AI as infrastructure, not a content shortcut", desc: "Building vision-intelligence, an AI marketing platform for DACH SMEs, as a solo project. I can audit your current AI usage, identify three high-leverage automations, and have the first one running in the first month." },
          ].map(({ title, desc }, i) => (
            <div class="flex flex-col md:flex-row gap-4 py-8 group">
              <span class="text-[11px] tracking-widest text-muted-foreground w-10 shrink-0 pt-1" style="font-family: var(--font-body)">{String(i + 1).padStart(2, "0")}</span>
              <div class="md:w-1/3 shrink-0">
                <p style="font-family: var(--font-display); font-weight: 600; font-size: clamp(1rem, 1.5vw, 1.2rem); letter-spacing: -0.01em; line-height: 1.2;">{title}</p>
              </div>
              <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{desc}</p>
            </div>
          ))}
        </div>

        <div class="mt-10">
          <a href="/ai-marketing-dach" class="text-[13px] text-muted-foreground hover:text-foreground transition-colors duration-200 underline underline-offset-4" style="font-family: var(--font-body)">
            Read the full AI marketing framework →
          </a>
        </div>
      </div>
    </section>

    <!-- Contact CTA -->
    <section class="bg-foreground text-background">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-16 pb-8">
        <p style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;" class="mb-10">
          Start with a<br /><span class="italic font-light">discovery call.</span>
        </p>
        <div class="flex flex-wrap gap-4 mb-12">
          <a href="https://cal.com/saralogy/15min" target="_blank" rel="noopener noreferrer"
            class="text-[11px] tracking-widest uppercase bg-white text-black px-6 py-3 hover:bg-white/90 transition-opacity"
            style="font-family: var(--font-body)">
            Book 15 min
          </a>
          <a href="mailto:berksaraloglu@gmail.com?subject=Consulting%20enquiry%20via%20saralogy.com"
            class="text-[11px] tracking-widest uppercase border border-white/30 px-6 py-3 hover:bg-white hover:text-black transition-all duration-200"
            style="font-family: var(--font-body)">
            Email Berk
          </a>
        </div>
        <div class="border-t border-white/10 pt-6">
          <p class="text-[11px] text-white/30 tracking-wider" style="font-family: var(--font-body)">
            berksaraloglu@gmail.com · I respond to specific enquiries within 48 hours.
          </p>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Base>
