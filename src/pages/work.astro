---
import Base from "@layouts/Base.astro";
import "../styles/global.css";
---

<Base
  title="Work with Berk Saraloglu — Senior Marketing Manager, DACH"
  description="Berk Saraloglu is actively seeking a Senior Marketing Manager role in Hamburg or DACH. Open to consulting on AI marketing transformation and product launch strategy."
>
  <header class="border-b border-gray-100">
    <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="font-semibold text-lg tracking-tight">saralogy.com</a>
      <div class="flex items-center gap-6 text-sm text-gray-600">
        <a href="/about" class="hover:text-gray-900 transition-colors">About</a>
        <a href="/career" class="hover:text-gray-900 transition-colors">Career</a>
        <a href="/music" class="hover:text-gray-900 transition-colors">Music</a>
        <a href="/projects" class="hover:text-gray-900 transition-colors">Projects</a>
        <a href="/work" class="text-gray-900 font-medium">Work with me</a>
      </div>
    </nav>
  </header>

  <main class="max-w-4xl mx-auto px-6">

    <section class="pt-16 pb-10 border-b border-gray-100">
      <div class="flex items-center gap-3 mb-6">
        <span class="inline-flex items-center gap-2 text-sm font-medium text-green-700 bg-green-100 px-3 py-1.5 rounded-full">
          <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
          Available now
        </span>
      </div>
      <h1 class="text-4xl font-bold text-gray-900 mb-4 leading-tight">
        Senior Marketing Manager<br />based in Hamburg
      </h1>
      <p class="text-xl text-gray-600 leading-relaxed max-w-2xl">
        10+ years in consumer electronics and lifestyle brand marketing. Looking for a senior
        role in Hamburg or the DACH region where I can own a full marketing function — ideally
        at a company that takes AI-native marketing seriously.
      </p>
    </section>

    <!-- What I'm looking for -->
    <section class="py-12 border-b border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">What I'm looking for</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          { label: "Location", value: "Hamburg or DACH (no relocation)" },
          { label: "Role level", value: "Senior Marketing Manager or equivalent" },
          { label: "Start", value: "Available immediately" },
          { label: "Industry fit", value: "Consumer electronics, lifestyle, B2B SaaS, AI/tech" },
          { label: "Company stage", value: "Scale-up to enterprise — team of ≥5 in marketing" },
        ].map(({ label, value }) => (
          <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
            <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">{label}</div>
            <div class="font-medium text-gray-900">{value}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- What I bring -->
    <section class="py-12 border-b border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">What I bring</h2>
      <div class="space-y-5">
        {[
          {
            title: "Product launch ownership",
            desc: "Ran the full-funnel launch of a premium airfryer at VeSync — 117% of sell-out target in 53 days across 8 channels simultaneously. Built 3 full-funnel playbooks validated through Jobs-to-Be-Done testing. I know what it takes to go from brief to shelf.",
          },
          {
            title: "Enterprise brand communications",
            desc: "4.5 years at BSH Siemens Global managing large-scale media budgets, generating significant organic media value annually, and delivering major production savings through centralised content systems. Created Siemens' first global Instagram presence and authored the social media playbook adopted across markets.",
          },
          {
            title: "Cross-functional leadership without authority",
            desc: "Led 15+ stakeholders across Germany and China HQ at VeSync without line authority. Aligned country teams across 10+ markets at BSH. I've done the hard part of international matrix management — building shared governance, not just sending emails.",
          },
          {
            title: "AI-native marketing thinking",
            desc: "I'm not just using AI tools — I'm building them. vision-intelligence is an AI marketing platform I'm developing for DACH SMEs. I understand both the strategic potential and the practical limits of AI in marketing because I'm working both sides of the equation.",
          },
        ].map(({ title, desc }) => (
          <div class="border border-gray-200 rounded-xl p-5">
            <h3 class="font-semibold text-gray-900 mb-2">{title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Consulting -->
    <section class="py-12 border-b border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Also available for consulting</h2>
      <p class="text-gray-600 leading-relaxed mb-6 max-w-2xl">
        While I look for the right permanent role, I take on selective consulting work in two areas:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-5 border border-gray-200 rounded-xl">
          <div class="font-semibold text-gray-900 mb-2">AI marketing transformation</div>
          <div class="text-sm text-gray-500">Help marketing teams implement AI-native workflows. Particularly relevant for DACH companies that want to move beyond "using ChatGPT to write captions."</div>
        </div>
        <div class="p-5 border border-gray-200 rounded-xl">
          <div class="font-semibold text-gray-900 mb-2">Product launch strategy</div>
          <div class="text-sm text-gray-500">Go-to-market planning and execution for product launches in the DACH market. From brief to sell-out strategy.</div>
        </div>
      </div>
    </section>

    <!-- Get in touch -->
    <section class="py-12">
      <div class="bg-gray-900 rounded-2xl p-8 text-white">
        <h2 class="text-2xl font-bold mb-2">Get in touch</h2>
        <p class="text-gray-400 mb-6 text-sm leading-relaxed">
          The best way to reach me is LinkedIn. I respond to messages that are specific
          about the role or project — "we're building X and need someone to own Y" is the
          kind of brief I can respond to quickly.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="https://linkedin.com/in/berksaraloglu"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white text-gray-900 px-6 py-2.5 rounded-full font-medium text-sm hover:bg-gray-100 transition-colors"
          >
            Message on LinkedIn →
          </a>
          <a
            href="/about"
            class="border border-gray-700 text-gray-300 px-6 py-2.5 rounded-full font-medium text-sm hover:border-gray-400 transition-colors"
          >
            Full background →
          </a>
        </div>
      </div>
    </section>

  </main>

  <footer class="border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-6 py-8 flex items-center justify-between text-sm text-gray-500">
      <span>© 2026 Berk Saraloglu</span>
      <div class="flex gap-6">
        <a href="/now" class="hover:text-gray-900 transition-colors">Now</a>
        <a href="https://linkedin.com/in/berksaraloglu" target="_blank" rel="noopener" class="hover:text-gray-900 transition-colors">LinkedIn</a>
        <a href="https://github.com/berksaraloglu" target="_blank" rel="noopener" class="hover:text-gray-900 transition-colors">GitHub</a>
      </div>
    </div>
  </footer>
</Base>
