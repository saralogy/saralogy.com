---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import Header from "@components/Header.astro";
import "../../styles/global.css";

const entries = await getCollection("career", ({ data }) => data.status === "published");

const buildLines: Record<string, string> = {
  vesync: "Built 3 full-funnel launch playbooks; hit 117% of flagship product sell-out target in 53 days.",
  bsh: "Built Siemens' first global Instagram presence and the content playbook adopted across 10+ markets.",
  samsung: "Built 150 brand stores nationally and a YouTube format adopted as the Samsung EMEA benchmark.",
  orma: "Opened the architect and designer segment from scratch; led full website and app redesign in 4 months.",
};

// Sort by end date descending (most recent first)
const sorted = entries.sort((a, b) => {
  const endA = a.data.period.end === "present" ? "9999-99" : a.data.period.end;
  const endB = b.data.period.end === "present" ? "9999-99" : b.data.period.end;
  return endB.localeCompare(endA);
});

function formatPeriod(start: string, end: string) {
  const fmt = (s: string) => {
    if (s === "present") return "Present";
    const [y, m] = s.split("-");
    const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    return `${months[parseInt(m) - 1]} ${y}`;
  };
  return `${fmt(start)} – ${fmt(end)}`;
}
---

<Base
  title="Career — Marketing Leadership & Product Strategy | Berk Saraloglu"
  description="Building marketing at three scales: startup (VeSync), corporate (BSH/Siemens), and solo. Consumer electronics, global brand, full-funnel launches. Based in Hamburg. Full career history with case studies."
>
  <Header />

  <main class="max-w-4xl mx-auto px-6">

    <section class="pt-16 pb-10 border-b border-gray-100">
      <p class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-4">Hamburg, Germany</p>
      <h1 class="text-4xl font-bold text-gray-900 mb-4 leading-tight">Career</h1>
      <p class="text-xl text-gray-600 leading-relaxed max-w-2xl">
        Building marketing at three scales: startup (VeSync), corporate (BSH/Siemens), and solo (vision-intelligence).
        Each page below is a case study, not a CV line. What the role was, what I actually built, and what it means today.
      </p>
    </section>

    <!-- Timeline -->
    <section class="py-12">
      {sorted.length > 0 ? (
        <div class="space-y-4">
          {sorted.map((entry) => {
            const d = entry.data;
            const period = formatPeriod(d.period.start, d.period.end);
            return (
              <a
                href={`/career/${entry.slug}`}
                class="group flex items-start gap-6 p-6 border border-gray-200 rounded-xl hover:border-gray-900 transition-colors"
              >
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 mb-1 flex-wrap">
                    <span class="font-semibold text-gray-900">{d.company}</span>
                    <span class="text-xs text-gray-400">{d.location}</span>
                  </div>
                  <div class="text-sm text-gray-500 mb-2">{d.role} · {period}</div>
                  {buildLines[entry.slug] && (
                    <p class="text-sm text-gray-600 mb-3">{buildLines[entry.slug]}</p>
                  )}
                  <div class="flex flex-wrap gap-2">
                    {d.wins.slice(0, 3).map((w) => (
                      <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">
                        {w.metric ?? w.headline.split(" ").slice(0, 4).join(" ")}
                      </span>
                    ))}
                  </div>
                </div>
                <span class="text-gray-400 group-hover:text-gray-900 transition-colors text-xl shrink-0 mt-1">→</span>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-20 text-gray-400">
          <p>Career pages coming soon.</p>
        </div>
      )}
    </section>

    <!-- Education -->
    <section class="py-10 border-t border-gray-100">
      <h2 class="text-xl font-bold text-gray-900 mb-2">Education</h2>
      <p class="text-sm text-gray-500 mb-6 max-w-2xl">
        Industrial Design before Marketing Communication. That sequence matters: it means I think in systems and user flows before I think in messages. Most marketers learn the product after the brief. I learned how products are conceived.
      </p>
      <div class="space-y-4">
        {[
          { degree: "M.A. Marketing Communication", school: "Istanbul Bilgi University", year: "2016–2018", note: "Built the strategic layer on top of a design foundation." },
          { degree: "B.Sc. Industrial Design", school: "Middle East Technical University", year: "2009–2014", note: "Exchange: Politecnico di Torino. Trained to design for human behaviour before designing for attention." },
        ].map(({ degree, school, year, note }) => (
          <div class="flex items-start justify-between p-5 border border-gray-100 rounded-xl bg-gray-50">
            <div>
              <div class="font-medium text-gray-900">{degree}</div>
              <div class="text-sm text-gray-500">{school}</div>
              {note && <div class="text-xs text-gray-400 mt-0.5">{note}</div>}
            </div>
            <span class="text-sm text-gray-400 shrink-0 ml-4">{year}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="py-8 border-t border-gray-100">
      <a href="/work" class="inline-flex items-center gap-2 bg-gray-900 text-white px-6 py-3 rounded-full font-medium text-sm hover:bg-gray-700 transition-colors">
        Available for hire →
      </a>
    </section>

  </main>

  <footer class="border-t border-gray-100 mt-4">
    <div class="max-w-4xl mx-auto px-6 py-8 flex flex-col sm:flex-row gap-4 sm:items-center sm:justify-between text-sm text-gray-500">
      <span>© 2026 Berk Saraloglu · AI-native marketing leader in Hamburg</span>
      <div class="flex gap-6">
        <a href="/now" class="hover:text-gray-900 transition-colors">Now</a>
        <a href="/music" class="hover:text-gray-900 transition-colors">Music</a>
        <a href="mailto:berksaraloglu@gmail.com?subject=Opportunity%20via%20saralogy.com" class="hover:text-gray-900 transition-colors">Email</a>
        <a href="https://linkedin.com/in/berksaraloglu" target="_blank" rel="noopener" class="hover:text-gray-900 transition-colors">LinkedIn</a>
        <a href="https://github.com/berksaraloglu" target="_blank" rel="noopener" class="hover:text-gray-900 transition-colors">GitHub</a>
      </div>
    </div>
  </footer>
</Base>
