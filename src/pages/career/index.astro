---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import "../../styles/global.css";
import { Marquee }        from "@components/Marquee";
import { NavHeader }      from "@components/NavHeader";
import { SiteFooter }     from "@components/SiteFooter";
import { CareerTimeline, type CareerEntry } from "@components/CareerTimeline";

const raw = await getCollection("career", ({ data }) => data.status === "published");

const categoryMap: Record<string, CareerEntry["category"]> = {
  bsh:     "corporate",
  samsung: "corporate",
  vesync:  "startup",
  orma:    "early",
};

function formatPeriod(start: string, end: string) {
  const fmt = (s: string) => {
    if (s === "present") return "Present";
    const [y, m] = s.split("-");
    const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    return `${months[parseInt(m) - 1]} ${y}`;
  };
  return `${fmt(start)} – ${fmt(end)}`;
}

const highlights: Record<string, string> = {
  vesync:  "Built 3 full-funnel launch playbooks; hit 117% of flagship sell-out target in 53 days.",
  bsh:     "Built Siemens' first global Instagram presence and a content playbook adopted across 10+ markets.",
  samsung: "Built 150 brand stores nationally and a YouTube format adopted as the Samsung EMEA benchmark.",
  orma:    "Opened the architect and designer segment from scratch; led full website and app redesign in 4 months.",
};

const entries: CareerEntry[] = raw
  .sort((a, b) => {
    const ea = a.data.period.end === "present" ? "9999-99" : a.data.period.end;
    const eb = b.data.period.end === "present" ? "9999-99" : b.data.period.end;
    return eb.localeCompare(ea);
  })
  .map((e) => ({
    slug:     e.slug,
    company:  e.data.company,
    role:     e.data.role,
    location: e.data.location,
    period:   formatPeriod(e.data.period.start, e.data.period.end),
    highlight: highlights[e.slug] ?? "",
    wins:     e.data.wins ?? [],
    category: categoryMap[e.slug] ?? "early",
  }));
---

<Base
  title="Career — Marketing Leadership | Berk Saraloglu"
  description="Marketing at three scales: startup (VeSync), corporate (BSH/Siemens), and early (Samsung, ORMA). Full career history with case studies. Based in Hamburg."
>
  <Marquee client:load />
  <NavHeader client:load />

  <main>
    <!-- Page header -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-20 pb-14 flex flex-col md:flex-row md:items-end md:justify-between gap-8">
        <div>
          <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-3" style="font-family: var(--font-body)">
            ✦ Hamburg, Germany
          </span>
          <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(3rem, 7vw, 6rem); line-height: 0.95; letter-spacing: -0.03em;">
            Career.
          </h1>
        </div>
        <p class="max-w-sm text-sm text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
          Marketing at three scales: startup, corporate, and early-career. Each entry below is a case study — what the role was, what I actually built, and what it means today.
        </p>
      </div>
    </section>

    <!-- Interactive timeline -->
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 py-20">
      {entries.length > 0 ? (
        <CareerTimeline entries={entries} client:load />
      ) : (
        <p class="text-muted-foreground text-sm py-20 text-center" style="font-family: var(--font-body)">Career pages coming soon.</p>
      )}
    </section>

    <!-- Education -->
    <section class="border-t border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12">
          <div>
            <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-3" style="font-family: var(--font-body)">
              ✦ Education
            </span>
            <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;">
              Foundation.
            </h2>
          </div>
          <p class="max-w-sm text-sm text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
            Industrial Design before Marketing Communication. That sequence matters — I think in systems before I think in messages.
          </p>
        </div>

        <div class="flex flex-col divide-y divide-border">
          {[
            { degree: "M.A. Marketing Communication", school: "Istanbul Bilgi University", year: "2016–2018", note: "Built the strategic layer on top of a design foundation." },
            { degree: "B.Sc. Industrial Design", school: "Middle East Technical University", year: "2009–2014", note: "Exchange: Politecnico di Torino. Trained to design for human behaviour before attention." },
          ].map(({ degree, school, year, note }) => (
            <div class="flex flex-col md:flex-row md:items-center gap-4 py-6">
              <span class="text-[11px] tracking-widest text-muted-foreground w-10 shrink-0" style="font-family: var(--font-body)">↗</span>
              <div class="md:w-1/3">
                <p style="font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; letter-spacing: -0.01em;">{degree}</p>
                <p class="text-[12px] text-muted-foreground mt-0.5" style="font-family: var(--font-body)">{school}</p>
              </div>
              <p class="md:w-1/2 text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{note}</p>
              <span class="md:ml-auto text-[11px] text-muted-foreground shrink-0" style="font-family: var(--font-body)">{year}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="border-t border-border bg-foreground text-background">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <p style="font-family: var(--font-display); font-weight: 700; font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1; letter-spacing: -0.02em;">
          Available for the right role.
        </p>
        <a
          href="/work"
          class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase border border-white/30 px-6 py-3 hover:bg-white hover:text-black transition-all duration-200"
          style="font-family: var(--font-body)"
        >
          Work with me
          <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M7 1l4 3.5m0 0L7 8m4-3.5H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
        </a>
      </div>
    </section>
  </main>

  <SiteFooter />
</Base>
