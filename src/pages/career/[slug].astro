---
import { getCollection, type CollectionEntry } from "astro:content";
import Base from "@layouts/Base.astro";
import "../../styles/global.css";
import { Marquee }    from "@components/Marquee";
import { NavHeader }  from "@components/NavHeader";
import { SiteFooter } from "@components/SiteFooter";

export async function getStaticPaths() {
  const entries = await getCollection("career", ({ data }) => data.status === "published");
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

type Props = { entry: CollectionEntry<"career"> };
const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;

function formatPeriod(start: string, end: string) {
  const fmt = (s: string) => {
    if (s === "present") return "Present";
    const [y, m] = s.split("-");
    const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    return `${months[parseInt(m) - 1]} ${y}`;
  };
  return `${fmt(start)} – ${fmt(end)}`;
}
const period = formatPeriod(d.period.start, d.period.end);

const roleFaqs: Record<string, {q: string; a: string}[]> = {
  vesync: [
    { q: "What did Berk Saraloglu achieve at VeSync?", a: "117% of premium airfryer sell-out target in 53 days across 8 channels. 4.0% conversion rate against a 2.5% category benchmark. 7.07x blended ROAS. Built a 22-module EU IMC operating system adopted by Spain and France as the regional standard." },
    { q: "How did the VeSync airfryer launch reach 117% in 53 days?", a: "Built around the Jobs-to-Be-Done framework. Consumer interviews identified the real purchase trigger. Those insights shaped the creative brief, keyword strategy, and influencer selection simultaneously. Seven channels ran in parallel, each anchored to the same JTBD foundation." },
  ],
  bsh: [
    { q: "What did Berk Saraloglu accomplish at BSH?", a: "Built Siemens' first global Instagram account, developed a purchase-intent SEO content strategy generating €M+ in annual organic media value across 10+ countries, achieved 600% CRM database growth in the Netherlands, and saved significantly through content centralisation across 3 continents." },
    { q: "How did Berk Saraloglu scale content across 10+ countries at Siemens?", a: "Redesigned the content strategy around purchase intent rather than brand awareness, deploying comparison guides, how-to videos, and product explainers across 10+ countries. Content was centralised into a unified global playbook, eliminating the pattern of 12 country teams briefing 12 agencies on the same campaign." },
  ],
  samsung: [
    { q: "What awards did Berk Saraloglu win at Samsung?", a: "3 Kristal Elma Awards in 2019 — Turkey's equivalent of Cannes Lions. Silver for Creative Engaging Contents, Silver for Best Branded Content, Bronze for Best Product Placement Content. The winning campaign was the Göbeklitepe UNESCO documentary shot on Samsung mobile." },
    { q: "How many stores did Berk Saraloglu launch at Samsung?", a: "Directed the national rollout of 150 Samsung brand experience stores across Turkey in two years, achieving a 40% reduction in project timeline and a 15–24% reduction in fixture production costs." },
  ],
  orma: [
    { q: "What did Berk Saraloglu do at ORMA?", a: "Built B2B market expansion into the architect and designer segment from zero and led a full UX/UI redesign of the company's brand website and mobile application." },
  ],
};
const faqItems = roleFaqs[entry.slug] ?? [];
---

<Base title={d.seo.title} description={d.seo.description}>
  <Marquee client:load />
  <NavHeader client:load />

  <main>
    <!-- Page header -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-16 pb-14">
        <!-- Breadcrumb -->
        <a href="/career" class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase text-muted-foreground hover:text-foreground transition-colors mb-10" style="font-family: var(--font-body)">
          <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M5 1L1 4.5m0 0L5 8M1 4.5h10" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
          Career
        </a>

        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-10">
          <div>
            <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-3" style="font-family: var(--font-body)">{d.location} · {period}</span>
            <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2.5rem, 6vw, 5.5rem); line-height: 0.95; letter-spacing: -0.03em;">
              {d.company}.
            </h1>
            <p class="text-muted-foreground mt-3" style="font-family: var(--font-body); font-size: clamp(1rem, 1.5vw, 1.2rem);">{d.role}</p>
          </div>

          {d.roleHistory && d.roleHistory.length > 1 && (
            <div class="flex flex-wrap gap-2 max-w-xs">
              {d.roleHistory.map((r: any) => (
                <span class="text-[10px] tracking-[0.15em] uppercase border border-border px-3 py-1.5 text-muted-foreground" style="font-family: var(--font-body)">
                  {r.title} · {r.period}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Key wins -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-px bg-border">
          {d.wins.slice(0, 6).map((w: any) => (
            <div class="bg-background px-6 py-8 flex flex-col gap-2">
              {w.metric && (
                <span style="font-family: var(--font-display); font-weight: 700; font-size: clamp(1.5rem, 2.5vw, 2.5rem); line-height: 1; letter-spacing: -0.03em;">
                  {w.metric}
                </span>
              )}
              <span class="text-[11px] tracking-wider text-muted-foreground leading-snug uppercase" style="font-family: var(--font-body)">{w.headline}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Story -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="flex items-baseline gap-4 mb-12">
          <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground" style="font-family: var(--font-body)">✦ The story</span>
          <span class="text-[10px] tracking-widest uppercase text-muted-foreground border border-border px-2.5 py-1" style="font-family: var(--font-body)">Permanent record</span>
        </div>
        <div class="grid grid-cols-12 gap-8">
          <div class="col-span-8 prose" style="--tw-prose-body: var(--muted-foreground); --tw-prose-headings: var(--foreground); font-family: var(--font-body); font-size: 0.875rem; line-height: 1.8;">
            <Content />
          </div>
          {d.posterImage && (
            <div class="col-span-4 flex items-start">
              <img src={d.posterImage} alt="Career poster" style="width: 100%; height: auto;" />
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-6" style="font-family: var(--font-body)">✦ Skills demonstrated</span>
          <div class="flex flex-wrap gap-2">
            {d.skills.map((s: string) => (
              <span class="text-[10px] tracking-[0.15em] uppercase border border-border px-3 py-1.5 text-muted-foreground" style="font-family: var(--font-body)">{s}</span>
            ))}
          </div>
        </div>
        {d.tools && (
          <div>
            <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-6" style="font-family: var(--font-body)">✦ Tools</span>
            <div class="flex flex-wrap gap-2">
              {d.tools.map((t: string) => (
                <span class="text-[10px] tracking-[0.15em] uppercase bg-muted text-muted-foreground px-3 py-1.5" style="font-family: var(--font-body)">{t}</span>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Current relevance -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="flex items-baseline gap-4 mb-8">
          <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground" style="font-family: var(--font-body)">✦ What this means today</span>
          <span class="text-[10px] tracking-widest uppercase text-muted-foreground border border-border px-2.5 py-1" style="font-family: var(--font-body)">
            Updated {new Date(d.currentRelevance.date).toLocaleDateString("en-GB", { month: "long", year: "numeric" })}
          </span>
        </div>
        <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl mb-10" style="font-family: var(--font-body)">{d.currentRelevance.body}</p>

        {d.projectsFromHere && d.projectsFromHere.length > 0 && (
          <div>
            <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-6" style="font-family: var(--font-body)">Projects that started here</span>
            <div class="flex flex-col divide-y divide-border">
              {d.projectsFromHere.map((p: any) => (
                <a href={p.url} class="group flex items-center gap-4 py-4 hover:bg-card transition-colors duration-150">
                  <span class="flex-1 text-[13px] font-medium text-foreground group-hover:translate-x-1 transition-transform duration-200" style="font-family: var(--font-body)">{p.title}</span>
                  <span class="text-[12px] text-muted-foreground max-w-xs hidden md:block" style="font-family: var(--font-body)">{p.connection}</span>
                  <svg width="16" height="12" viewBox="0 0 16 12" fill="none" class="text-muted-foreground group-hover:text-foreground transition-colors shrink-0">
                    <path d="M10 1l5 5m0 0l-5 5m5-5H1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                  </svg>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Departure -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16">
        <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-6" style="font-family: var(--font-body)">✦ Why I left</span>
        <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl" style="font-family: var(--font-body)">{d.departureContext}</p>
      </div>
    </section>

    <!-- FAQ -->
    {faqItems.length > 0 && (
      <section class="border-b border-border">
        <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20">
          <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-12" style="font-family: var(--font-body)">✦ Quick answers</span>
          <div class="flex flex-col divide-y divide-border">
            {faqItems.map(({ q, a }) => (
              <div class="flex flex-col md:flex-row gap-4 py-6">
                <p class="md:w-1/3 shrink-0 text-[13px] font-medium text-foreground" style="font-family: var(--font-body)">{q}</p>
                <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{a}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="bg-foreground text-background">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <p style="font-family: var(--font-display); font-weight: 700; font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1; letter-spacing: -0.02em;">
          If this matches<br /><span class="italic font-light">what you're looking for.</span>
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="mailto:berksaraloglu@gmail.com?subject=Senior%20Marketing%20role%20via%20saralogy.com"
            class="text-[11px] tracking-widest uppercase bg-white text-black px-6 py-3 hover:bg-white/90 transition-opacity"
            style="font-family: var(--font-body)">
            Email Berk
          </a>
          <a href="/work"
            class="text-[11px] tracking-widest uppercase border border-white/30 px-6 py-3 hover:bg-white hover:text-black transition-all duration-200"
            style="font-family: var(--font-body)">
            See availability
          </a>
          <a href="/career"
            class="text-[11px] tracking-widest uppercase text-white/50 hover:text-white transition-colors duration-200"
            style="font-family: var(--font-body)">
            ← All tenures
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Base>
