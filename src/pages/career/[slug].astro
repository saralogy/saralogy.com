---
import { getCollection, type CollectionEntry } from "astro:content";
import Base from "@layouts/Base.astro";
import Header from "@components/Header.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
  const entries = await getCollection("career", ({ data }) => data.status === "published");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<"career"> };
const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;

// Format period for display
function formatPeriod(start: string, end: string) {
  const fmt = (s: string) => {
    if (s === "present") return "Present";
    const [y, m] = s.split("-");
    const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    return `${months[parseInt(m) - 1]} ${y}`;
  };
  return `${fmt(start)} – ${fmt(end)}`;
}

const period = formatPeriod(d.period.start, d.period.end);

// Per-role FAQ pairs for AI citability
const roleFaqs: Record<string, {q: string; a: string}[]> = {
  vesync: [
    { q: "What did Berk Saraloglu achieve at VeSync?", a: "Berk Saraloglu served as Integrated Marketing Manager EU at VeSync GmbH in Düsseldorf from November 2025 to May 2026. He achieved 117% of a premium airfryer sell-out target in 53 days across 8 channels simultaneously, with a 4.0% conversion rate against a 2.5% category benchmark and a 7.07x blended ROAS. He also built a 22-module EU IMC operating system adopted by Spain and France as the regional standard." },
    { q: "How did the VeSync airfryer launch reach 117% of target in 53 days?", a: "The launch was built around the Jobs-to-Be-Done framework. Consumer interviews identified the real purchase trigger — a specific cooking problem the product solved better than existing workarounds. Those insights shaped the creative brief, keyword strategy, and influencer selection simultaneously. Seven channels ran in parallel, each brief anchored to the same JTBD foundation. The result was 978 units sold at 4.0% conversion against a 2.5% category benchmark." },
    { q: "What marketing skills did Berk Saraloglu use at VeSync?", a: "At VeSync, Berk Saraloglu applied Jobs-to-Be-Done research methodology, omnichannel campaign management (Amazon, DTC, TikTok, Meta, Google Ads, influencer, retail media), cross-functional leadership without direct authority across Germany and China HQ, and full-funnel IMC governance framework design. He coordinated 15+ stakeholders across Germany, China, Spain, and France simultaneously." },
  ],
  bsh: [
    { q: "What did Berk Saraloglu accomplish at BSH (Bosch Siemens Home Appliances)?", a: "Berk Saraloglu spent 4.5 years at BSH Hausgeräte GmbH as Senior Brand Communications Manager for Siemens Global in Munich. He built Siemens' first global Instagram account, developed a purchase-intent SEO content strategy generating €M+ in annual organic media value across 10+ countries, achieved 600% CRM database growth in the Netherlands, and saved millions annually through content production centralisation across 3 continents." },
    { q: "What was the Kitchen Planning App that Berk Saraloglu built at BSH?", a: "Berk Saraloglu originated and led development of Siemens' first digital product — a Kitchen Planning App built in collaboration with TU Munich software engineers. The app addressed the consumer journey gap between kitchen inspiration and product selection. In pilot markets (Spain and Turkey), it increased purchase consideration by 80% as measured through online consumer surveys." },
    { q: "How did Berk Saraloglu scale content across 10+ countries at Siemens?", a: "He redesigned the content strategy around purchase intent rather than brand awareness, deploying comparison guides, how-to videos, and product explainers across 10+ countries. Content was centralised into a unified global playbook, eliminating the pattern of 12 country teams briefing 12 separate agencies on the same campaign. Production costs dropped by roughly 40% while output volume increased. The Bosch and Gaggenau brands subsequently adopted the framework." },
  ],
  samsung: [
    { q: "What awards did Berk Saraloglu win at Samsung Electronics?", a: "Berk Saraloglu won 3 Kristal Elma Awards in 2019 — Turkey's equivalent of the Cannes Lions for advertising excellence. He received Silver for Creative Engaging Contents, Silver for Best Branded Content, and Bronze for Best Product Placement Content. The winning campaign was the Göbeklitepe UNESCO cultural documentary, a 360-degree cinematic production of one of the world's oldest heritage sites shot on a Samsung mobile phone." },
    { q: "What was the Göbeklitepe campaign and why did it win awards?", a: "The Göbeklitepe campaign was a self-initiated project by Berk Saraloglu at Samsung Turkey in 2019. Rather than executing a standard product demo, he pitched a 360-degree Insta-documentary of Göbeklitepe — one of the oldest UNESCO heritage sites in the world — shot on Samsung's mobile phone. The campaign won three national advertising awards and drove a 13% increase in brand engagement on owned channels. The YouTube product comparison format developed alongside it was adopted as the Samsung EMEA regional benchmark." },
    { q: "How many stores did Berk Saraloglu launch at Samsung?", a: "Berk Saraloglu directed the national rollout of 150 Samsung brand experience stores across Turkey in two years. The rollout achieved a 40% reduction in project timeline (from 35 to 21 days per store) and a 15–24% reduction in fixture production costs. Post-launch, a systematic redesign of in-store display and merchandising architecture delivered a 20% increase in sales per square meter." },
  ],
  orma: [
    { q: "What did Berk Saraloglu do at ORMA?", a: "Berk Saraloglu worked as B2B Marketing Specialist at ORMA Chipwood in Istanbul from April 2015 to April 2016. He built B2B market expansion into the architect and designer segment from zero and led a full UX/UI redesign of the company's brand website and mobile application." },
    { q: "What was Berk Saraloglu's first marketing role?", a: "Berk Saraloglu's first professional marketing role was B2B Marketing Specialist at ORMA Chipwood in Istanbul (April 2015 – April 2016). ORMA is a manufacturing company. He developed the company's entry into the architect and designer segment and owned the brand's digital presence redesign." },
    { q: "How did Berk Saraloglu start in marketing?", a: "Berk Saraloglu started his marketing career at ORMA Chipwood in Istanbul in 2015, transitioning from an Industrial Design background (B.Sc. from Middle East Technical University, exchange at Politecnico di Torino). The ORMA role gave him first-hand experience in B2B demand generation and digital brand building before he moved into consumer electronics at Samsung Electronics in 2016." },
  ],
};

const faqItems = roleFaqs[entry.slug] ?? [];

// JSON-LD schema
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://saralogy.com/#person",
      "name": "Berk Saraloglu",
      "url": "https://saralogy.com",
      "worksFor": {
        "@type": "Organization",
        "name": d.company,
      },
    },
    {
      "@type": "Article",
      "headline": d.seo.title,
      "description": d.seo.description,
      "author": { "@id": "https://saralogy.com/#person" },
      "dateModified": d.lastReviewed,
      "mainEntityOfPage": `https://saralogy.com/career/${entry.slug}`,
    },
    ...(faqItems.length > 0 ? [{
      "@type": "FAQPage",
      "mainEntity": faqItems.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a },
      })),
    }] : []),
  ],
};
---

<Base title={d.seo.title} description={d.seo.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />

  <main class="max-w-4xl mx-auto px-6">

    <!-- Breadcrumb -->
    <div class="pt-8 pb-4">
      <a href="/career" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">← Career</a>
    </div>

    <!-- Header -->
    <section class="pb-10 border-b border-gray-100">
      <p class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-3">{d.location}</p>
      <h1 class="display-heading text-5xl sm:text-6xl text-gray-950 mb-2 leading-tight">{d.company}</h1>
      <p class="text-xl text-gray-500 mb-1">{d.role}</p>
      <p class="text-sm text-gray-400 mb-6">{period}</p>

      <!-- Role history (for multi-role tenures) -->
      {d.roleHistory && d.roleHistory.length > 1 && (
        <div class="flex flex-wrap gap-2 mb-6">
          {d.roleHistory.map((r) => (
            <div class="text-xs bg-gray-100 text-gray-600 px-3 py-1.5 rounded-full">
              <span class="font-medium">{r.title}</span>
              <span class="text-gray-400 ml-1">· {r.period}</span>
            </div>
          ))}
        </div>
      )}

      <!-- Key wins grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mt-6">
        {d.wins.slice(0, 6).map((w) => (
          <div class="p-4 bg-gray-50 rounded-xl border border-gray-100">
            {w.metric && (
              <div class="text-2xl font-bold text-gray-900 mb-1">{w.metric}</div>
            )}
            <div class="text-sm text-gray-600 leading-snug">{w.headline}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Permanent layer: the story -->
    <section class="py-10 border-b border-gray-100">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-xl font-bold text-gray-900">The story</h2>
        <span class="text-xs bg-gray-100 text-gray-500 px-2 py-1 rounded-full">Permanent record</span>
      </div>
      <div class="prose prose-gray max-w-none prose-headings:font-semibold prose-headings:text-gray-900 prose-p:text-gray-600 prose-p:leading-relaxed prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3 prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4">
        <Content />
      </div>
    </section>

    <!-- Skills used -->
    <section class="py-10 border-b border-gray-100">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Skills demonstrated</h2>
      <div class="flex flex-wrap gap-2">
        {d.skills.map((s) => (
          <span class="text-sm border border-gray-200 text-gray-700 px-3 py-1 rounded-full">{s}</span>
        ))}
      </div>
      {d.tools && (
        <div class="mt-4 flex flex-wrap gap-2">
          {d.tools.map((t) => (
            <span class="text-xs bg-gray-100 text-gray-500 px-2.5 py-1 rounded-full">{t}</span>
          ))}
        </div>
      )}
    </section>

    <!-- Living layer: current relevance -->
    <section class="py-10 border-b border-gray-100">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-xl font-bold text-gray-900">What this means today</h2>
        <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">
          Updated {new Date(d.currentRelevance.date).toLocaleDateString("en-GB", { month: "long", year: "numeric" })}
        </span>
      </div>
      <p class="text-gray-600 leading-relaxed">{d.currentRelevance.body}</p>

      <!-- Projects born from this role -->
      {d.projectsFromHere && d.projectsFromHere.length > 0 && (
        <div class="mt-8">
          <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-widest mb-4">Projects that started here</h3>
          <div class="space-y-3">
            {d.projectsFromHere.map((p) => (
              <a href={p.url} class="group flex items-start gap-4 p-4 surface-card-link">
                <div class="flex-1">
                  <div class="font-semibold text-gray-900 mb-1">{p.title}</div>
                  <div class="text-sm text-gray-500">{p.connection}</div>
                </div>
                <span class="text-gray-400 group-hover:text-gray-900 transition-colors text-lg mt-0.5">→</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- Departure context -->
    <section class="py-10 border-b border-gray-100">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Why I left</h2>
      <p class="text-gray-600 leading-relaxed">{d.departureContext}</p>
    </section>

    <!-- FAQ section (GEO: explicitly extractable Q&A pairs) -->
    {faqItems.length > 0 && (
      <section class="py-10 border-b border-gray-100">
        <h2 class="text-xl font-bold text-gray-900 mb-6">Quick answers</h2>
        <div class="space-y-5">
          {faqItems.map(({ q, a }) => (
            <div class="border-b border-gray-100 pb-5 last:border-0 last:pb-0">
              <h3 class="font-semibold text-gray-900 mb-2 text-sm">{q}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{a}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- CTA at peak persuasion — after the full case study read -->
    <section class="py-10 border-b border-gray-100">
      <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-2">If this matches what you are looking for</h2>
        <p class="text-sm text-gray-600 leading-relaxed mb-5">
          I am currently available for a Senior Marketing Manager role in Hamburg or DACH, and for selective consulting engagements in AI marketing transformation and product launch strategy.
          Email me with what you are working on. I respond within 48 hours.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="mailto:berksaraloglu@gmail.com?subject=Senior%20Marketing%20role%20via%20saralogy.com"
            class="btn-primary px-5 py-2 text-sm"
          >
            Email Berk →
          </a>
          <a
            href="/work"
            class="btn-secondary px-5 py-2 text-sm"
          >
            See full availability →
          </a>
        </div>
      </div>
    </section>

    <!-- Navigation -->
    <section class="py-10">
      <div class="flex items-center justify-between">
        <a href="/career" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">
          ← All tenures
        </a>
        <a href="/work" class="btn-primary px-6 py-2.5 text-sm">
          Work with me →
        </a>
      </div>
    </section>

  </main>

  <footer class="border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-6 py-8 flex flex-col sm:flex-row gap-4 sm:items-center sm:justify-between text-sm text-gray-500">
      <span>© 2026 Berk Saraloglu · AI-native marketing leader in Hamburg</span>
      <div class="flex gap-6">
        <a href="/now" class="hover:text-gray-900 transition-colors">Now</a>
        <a href="/music" class="hover:text-gray-900 transition-colors">Music</a>
        <a href="mailto:berksaraloglu@gmail.com?subject=Opportunity%20via%20saralogy.com" class="hover:text-gray-900 transition-colors">Email</a>
        <a href="https://linkedin.com/in/berksaraloglu" target="_blank" rel="noopener" class="hover:text-gray-900 transition-colors">LinkedIn</a>
        <a href="https://github.com/berksaraloglu" target="_blank" rel="noopener" class="hover:text-gray-900 transition-colors">GitHub</a>
      </div>
    </div>
  </footer>
</Base>
