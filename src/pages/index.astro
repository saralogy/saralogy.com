---
import Base from "@layouts/Base.astro";
import "../styles/global.css";
import { personSchemaJson } from "../data/schema";

import { Marquee }       from "@components/Marquee";
import { NavHeader }     from "@components/NavHeader";
import { Hero }          from "@components/Hero";
import IntentRouter      from "@components/IntentRouter.astro";
import { Stats }         from "@components/Stats";
import { Services }      from "@components/Services";
import { WorkShowcase }  from "@components/WorkShowcase";
import { Testimonials }  from "@components/Testimonials";
import { CaseStudy }     from "@components/CaseStudy";
import { SiteFooter }    from "@components/SiteFooter";
---

<Base
  title="Berk Saraloglu | AI Marketing · Hamburg"
  description="Turkish-German marketing leader and AI tool builder in Hamburg. 11+ years at Samsung, BSH Siemens, VeSync. Building AI-native marketing infrastructure for DACH SMEs."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={personSchemaJson} />
  </Fragment>

  <Marquee client:load />
  <NavHeader client:load />

  <main>
    <Hero client:load />
    <IntentRouter />
    <Stats />
    <Testimonials />
    <Services />
    <WorkShowcase />
    <CaseStudy />
  </main>

  <SiteFooter />
</Base>
