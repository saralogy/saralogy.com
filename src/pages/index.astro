---
import Base from "@layouts/Base.astro";
import "../styles/global.css";

const personSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://saralogy.com/#website",
      "url": "https://saralogy.com",
      "name": "saralogy.com",
      "description": "AI-native marketing for DACH SMEs — Berk Saraloglu",
      "publisher": { "@id": "https://saralogy.com/#person" },
    },
    {
      "@type": "Person",
      "@id": "https://saralogy.com/#person",
      "name": "Berk Saraloglu",
      "url": "https://saralogy.com",
      "jobTitle": "Marketing Leader & AI Tool Builder",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Hamburg",
        "addressCountry": "DE",
      },
    },
  ],
};
---

<Base
  title="Berk Saraloglu — AI Marketing · Music · Hamburg"
  description="Marketing leader and AI tool builder in Hamburg. 10+ years at Samsung, BSH Siemens, VeSync. Building AI-native marketing tools for DACH SMEs. Indie songwriter."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </Fragment>

  <!-- Nav -->
  <header class="border-b border-gray-100">
    <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="font-semibold text-lg tracking-tight">saralogy.com</a>
      <div class="flex items-center gap-6 text-sm text-gray-600">
        <a href="/about" class="hover:text-gray-900 transition-colors">About</a>
        <a href="/career" class="hover:text-gray-900 transition-colors">Career</a>
        <a href="/music" class="hover:text-gray-900 transition-colors">Music</a>
        <a href="/projects" class="hover:text-gray-900 transition-colors">Projects</a>
        <a href="/work" class="bg-gray-900 text-white px-4 py-1.5 rounded-full text-sm font-medium hover:bg-gray-700 transition-colors">
          Work with me
        </a>
      </div>
    </nav>
  </header>

  <main>
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-6 pt-24 pb-20">
      <div class="max-w-2xl">
        <p class="text-sm font-medium text-brand-600 mb-4 tracking-wide uppercase">Hamburg, Germany</p>
        <h1 class="text-5xl font-bold tracking-tight text-gray-900 mb-6 leading-tight">
          Marketing leader.<br />AI tool builder.<br />Songwriter.
        </h1>
        <p class="text-xl text-gray-600 leading-relaxed mb-10">
          10+ years building campaigns and products at Samsung, BSH Siemens, and VeSync.
          Now building AI-native marketing tools for DACH SMEs — and writing music on the side.
        </p>

        <!-- Intent Router: 3 audience paths -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <a href="/work" class="group p-5 border border-gray-200 rounded-xl hover:border-gray-900 transition-colors">
            <div class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Recruiter</div>
            <div class="font-semibold text-gray-900 mb-1">Available for hire</div>
            <div class="text-sm text-gray-500 group-hover:text-gray-700">Senior Marketing Manager, DACH →</div>
          </a>
          <a href="/ai-marketing-dach" class="group p-5 border border-gray-200 rounded-xl hover:border-gray-900 transition-colors">
            <div class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">SME Founder</div>
            <div class="font-semibold text-gray-900 mb-1">AI marketing tools</div>
            <div class="text-sm text-gray-500 group-hover:text-gray-700">For DACH businesses →</div>
          </a>
          <a href="/music" class="group p-5 border border-gray-200 rounded-xl hover:border-gray-900 transition-colors">
            <div class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Music</div>
            <div class="font-semibold text-gray-900 mb-1">Indie songwriter</div>
            <div class="text-sm text-gray-500 group-hover:text-gray-700">Songs and process →</div>
          </a>
        </div>
      </div>
    </section>

    <!-- The argument -->
    <section class="bg-gray-50 border-y border-gray-100">
      <div class="max-w-4xl mx-auto px-6 py-16">
        <div class="max-w-2xl">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">The thesis</h2>
          <p class="text-lg text-gray-600 leading-relaxed">
            AI-native marketing is the only viable path for DACH SMEs in the next five years —
            and most of them are years behind. I'm building the proof from two directions
            simultaneously: from inside, as the marketing leader who has done it at enterprise
            scale, and from outside, as the product developer building the tools to make it accessible.
          </p>
        </div>
      </div>
    </section>

    <!-- Career highlights -->
    <section class="max-w-4xl mx-auto px-6 py-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Where I've worked</h2>
      <div class="space-y-4">
        {[
          { company: "VeSync GmbH", role: "Integrated Marketing Manager EU", period: "2025–2026", slug: "vesync", highlight: "117% of premium launch target in 53 days" },
          { company: "BSH / Siemens Global", role: "Senior Brand Communications Manager", period: "2020–2024", slug: "bsh", highlight: "Significant organic media value across 10+ countries. Major production savings via centralised playbook." },
          { company: "Samsung Electronics", role: "Digital Marketing Specialist", period: "2016–2020", slug: "samsung", highlight: "3× Kristal Elma Awards, 100+ campaigns" },
        ].map((t) => (
          <a href={`/career/${t.slug}`} class="group flex items-center justify-between p-5 border border-gray-200 rounded-xl hover:border-gray-900 transition-colors">
            <div>
              <div class="font-semibold text-gray-900">{t.company}</div>
              <div class="text-sm text-gray-500">{t.role} · {t.period}</div>
              <div class="text-sm text-gray-600 mt-1 italic">"{t.highlight}"</div>
            </div>
            <div class="text-gray-400 group-hover:text-gray-900 transition-colors text-xl">→</div>
          </a>
        ))}
      </div>
      <a href="/career" class="inline-block mt-6 text-sm font-medium text-brand-600 hover:text-brand-700">
        Full career history →
      </a>
    </section>

    <!-- Currently building -->
    <section class="bg-gray-50 border-y border-gray-100">
      <div class="max-w-4xl mx-auto px-6 py-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">Currently building</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="/projects/vision-intelligence" class="group p-5 border border-gray-200 rounded-xl bg-white hover:border-gray-900 transition-colors">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xs font-medium bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">MVP</span>
            </div>
            <div class="font-semibold text-gray-900 mb-1">vision-intelligence</div>
            <div class="text-sm text-gray-500">AI marketing platform for DACH SMEs</div>
          </a>
          <a href="/projects/resume-matcher" class="group p-5 border border-gray-200 rounded-xl bg-white hover:border-gray-900 transition-colors">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xs font-medium bg-green-100 text-green-700 px-2 py-0.5 rounded-full">Live</span>
            </div>
            <div class="font-semibold text-gray-900 mb-1">resume-matcher</div>
            <div class="text-sm text-gray-500">ATS optimization for job seekers in Germany</div>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-6 py-8 flex items-center justify-between text-sm text-gray-500">
      <span>© 2026 Berk Saraloglu</span>
      <div class="flex gap-6">
        <a href="/now" class="hover:text-gray-900 transition-colors">Now</a>
        <a href="https://linkedin.com/in/berksaraloglu" target="_blank" rel="noopener" class="hover:text-gray-900 transition-colors">LinkedIn</a>
        <a href="https://github.com/berksaraloglu" target="_blank" rel="noopener" class="hover:text-gray-900 transition-colors">GitHub</a>
      </div>
    </div>
  </footer>
</Base>
