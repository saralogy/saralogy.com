---
import Base from "@layouts/Base.astro";
import "../styles/global.css";
import { Marquee }    from "@components/Marquee";
import { NavHeader }  from "@components/NavHeader";
import { SiteFooter } from "@components/SiteFooter";
import { icps }       from "../data/icps";
---

<Base
  title="Start Here | Work With or Hire Berk Saraloglu"
  description="Two ways to work with Berk Saraloglu: hire him for a Senior Marketing role in Hamburg/DACH, or engage him for fixed-scope AI marketing consulting for your SME. Pick your path."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://saralogy.com" },
          { "@type": "ListItem", "position": 2, "name": "Start Here", "item": "https://saralogy.com/start" }
        ]
      },
      {
        "@type": "ItemList",
        "name": "Ways to work with Berk Saraloglu",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Hire Berk for a Senior Marketing role", "url": "https://saralogy.com/open-to-work" },
          { "@type": "ListItem", "position": 2, "name": "AI marketing consulting for your SME", "url": "https://saralogy.com/work" }
        ]
      }
    ]
  })} />
  <Marquee client:load />
  <NavHeader client:load />

  <main>
    <!-- Hero -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-20 pb-14">
        <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-8" style="font-family: var(--font-body)">✦ Start here</span>
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-10">
          <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2.5rem, 6vw, 5.5rem); line-height: 0.95; letter-spacing: -0.03em;">
            Two ways to<br /><span class="italic font-light">work with me.</span>
          </h1>
          <p class="max-w-sm text-sm text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
            I keep this simple. You're either here to hire me into a role, or to bring me into your company for a fixed-scope engagement. Pick the path that fits and you'll have everything you need to decide — and a direct way to reach me.
          </p>
        </div>
      </div>
    </section>

    <!-- Two paths -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-2 gap-px bg-border">
        {icps.map((icp, idx) => (
          <div class="bg-background p-8 md:p-12 flex flex-col gap-8">
            <div>
              <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-4" style="font-family: var(--font-body)">
                Path {String(idx + 1).padStart(2, "0")} · {icp.label}
              </span>
              <p style="font-family: var(--font-display); font-weight: 700; font-size: clamp(1.6rem, 3vw, 2.4rem); line-height: 1.05; letter-spacing: -0.02em;">
                {icp.selfId}
              </p>
              <p class="mt-4 text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
                {icp.situation}
              </p>
            </div>

            <!-- Qualifiers -->
            <div>
              <span class="text-[10px] tracking-[0.2em] uppercase text-muted-foreground block mb-4" style="font-family: var(--font-body)">This is you if</span>
              <ul class="flex flex-col gap-2.5">
                {icp.qualifiers.map((q) => (
                  <li class="flex gap-3 text-[13px] leading-relaxed" style="font-family: var(--font-body)">
                    <span class="text-muted-foreground shrink-0">—</span>
                    <span>{q}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Open questions answered downstream -->
            <div>
              <span class="text-[10px] tracking-[0.2em] uppercase text-muted-foreground block mb-4" style="font-family: var(--font-body)">What you'll get answered</span>
              <ul class="flex flex-col gap-2">
                {icp.openQuestions.map((qq) => (
                  <li class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{qq}</li>
                ))}
              </ul>
            </div>

            <!-- Proof -->
            <div class="border-t border-border pt-6">
              <p style="font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; letter-spacing: -0.01em;" class="mb-1">{icp.proof.stat}</p>
              <p class="text-[12px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{icp.proof.context}</p>
            </div>

            <!-- CTAs -->
            <div class="mt-auto flex flex-wrap gap-3">
              <a href={icp.primaryCta.href}
                class="text-[11px] tracking-widest uppercase bg-foreground text-background px-5 py-2.5 hover:opacity-80 transition-opacity duration-200"
                style="font-family: var(--font-body)">
                {icp.primaryCta.label}
              </a>
              <a href={icp.secondaryCta.href}
                target={icp.secondaryCta.href.startsWith("http") ? "_blank" : undefined}
                rel={icp.secondaryCta.href.startsWith("http") ? "noopener noreferrer" : undefined}
                class="text-[11px] tracking-widest uppercase border border-border px-5 py-2.5 hover:border-foreground transition-colors duration-200 text-muted-foreground hover:text-foreground"
                style="font-family: var(--font-body)">
                {icp.secondaryCta.label}
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Reassurance / direct contact -->
    <section class="bg-foreground text-background">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-16 pb-8">
        <p style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;" class="mb-6">
          Still not sure<br /><span class="italic font-light">which one?</span>
        </p>
        <p class="max-w-md text-sm text-white/60 leading-relaxed mb-10" style="font-family: var(--font-body)">
          Just email me one line about your situation and I'll point you to the right path. I read every message and respond to specific enquiries within 48 hours.
        </p>
        <div class="flex flex-wrap gap-4 mb-12">
          <a href="mailto:berksaraloglu@gmail.com?subject=via%20saralogy.com%2Fstart"
            class="text-[11px] tracking-widest uppercase bg-white text-black px-6 py-3 hover:bg-white/90 transition-opacity"
            style="font-family: var(--font-body)">
            Email Berk
          </a>
          <a href="https://cal.com/saralogy/15min" target="_blank" rel="noopener noreferrer"
            class="text-[11px] tracking-widest uppercase border border-white/30 px-6 py-3 hover:bg-white hover:text-black transition-all duration-200"
            style="font-family: var(--font-body)">
            Book 15 min
          </a>
          <a href="https://linkedin.com/in/berksaraloglu" target="_blank" rel="noopener noreferrer"
            class="text-[11px] tracking-widest uppercase border border-white/30 px-6 py-3 hover:bg-white hover:text-black transition-all duration-200 text-white/60 hover:text-black"
            style="font-family: var(--font-body)">
            LinkedIn ↗
          </a>
        </div>
        <div class="border-t border-white/10 pt-6">
          <p class="text-[11px] text-white/30 tracking-wider" style="font-family: var(--font-body)">
            berksaraloglu@gmail.com · Hamburg, Germany · I respond to specific enquiries within 48 hours.
          </p>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Base>
