---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import "../styles/global.css";
import { Marquee }       from "@components/Marquee";
import { NavHeader }     from "@components/NavHeader";
import { SiteFooter }    from "@components/SiteFooter";
import { ProjectsGrid, type ProjectEntry } from "@components/ProjectsGrid";

const raw = await getCollection("projects", ({ data }) => data.status === "published");

const entries: ProjectEntry[] = raw
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return (a.data.order ?? 999) - (b.data.order ?? 999);
  })
  .map((e) => ({
    slug:          e.slug,
    title:         e.data.title,
    tagline:       e.data.tagline,
    problem:       e.data.problem,
    audience:      e.data.audience,
    projectStatus: e.data.projectStatus,
    techStack:     e.data.techStack ?? [],
    proofPoint:    e.data.proofPoint,
    liveUrl:       e.data.liveUrl,
    waitlistUrl:   e.data.waitlistUrl,
    githubUrl:     e.data.githubUrl,
    featured:      e.data.featured ?? false,
  }));
---

<Base
  title="Projects — AI Tools & Marketing Products | Berk Saraloglu"
  description="Products at the intersection of marketing, AI, and problems Berk saw at scale. Vision-intelligence for DACH SMEs and more."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://saralogy.com" },
      { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://saralogy.com/projects" }
    ]
  })} />
  <Marquee client:load />
  <NavHeader client:load />

  <main>
    <!-- Page header -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-20 pb-14 flex flex-col md:flex-row md:items-end md:justify-between gap-8">
        <div>
          <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-3" style="font-family: var(--font-body)">
            ✦ Building
          </span>
          <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(3rem, 7vw, 6rem); line-height: 0.95; letter-spacing: -0.03em;">
            Projects.
          </h1>
        </div>
        <p class="max-w-sm text-sm text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
          Products at the intersection of marketing, AI, and the problems I saw at scale. Each project solves something real, validated in practice.
        </p>
      </div>
    </section>

    <!-- Interactive grid -->
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 py-20">
      {entries.length > 0 ? (
        <ProjectsGrid entries={entries} client:load />
      ) : (
        <p class="text-muted-foreground text-sm py-20 text-center" style="font-family: var(--font-body)">Projects coming soon.</p>
      )}
    </section>

    <!-- Why these projects -->
    <section class="border-t border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="max-w-[1440px] grid grid-cols-1 md:grid-cols-2 gap-px bg-border">
          <div class="bg-background p-10">
            <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-6" style="font-family: var(--font-body)">
              ✦ The pattern
            </span>
            <p class="text-sm text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              Every project here solves a structural gap I encountered at scale. Vision-intelligence came from seeing the same content infrastructure problem repeat at BSH and VeSync. The pattern: work in the product space, observe the gap, build the tool, validate it, then decide if it's a business or a service.
            </p>
          </div>
          <div class="bg-background p-10">
            <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-6" style="font-family: var(--font-body)">
              ✦ The approach
            </span>
            <p class="text-sm text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">
              Some projects stay exploration. Some become the next venture. What links them: each starts with a problem I couldn't find a good tool for, built lean, tested with real users, and priced for the mid-market where the gap is largest.
            </p>
            <a
              href="/career"
              class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase border-b border-foreground pb-px hover:gap-4 transition-all duration-200 mt-6 block"
              style="font-family: var(--font-body)"
            >
              See the career pattern that led here
              <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M7 1l4 3.5m0 0L7 8m4-3.5H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="border-t border-border bg-foreground text-background">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <p style="font-family: var(--font-display); font-weight: 700; font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1; letter-spacing: -0.02em;">
          See how these tools<br /><span class="italic font-light">would help you build.</span>
        </p>
        <a
          href="/work"
          class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase border border-white/30 px-6 py-3 hover:bg-white hover:text-black transition-all duration-200 self-start"
          style="font-family: var(--font-body)"
        >
          Work with me
          <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M7 1l4 3.5m0 0L7 8m4-3.5H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
        </a>
      </div>
    </section>
  </main>

  <SiteFooter />
</Base>
