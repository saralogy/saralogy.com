---
import Base from "@layouts/Base.astro";
import "../styles/global.css";
import { Marquee }    from "@components/Marquee";
import { NavHeader }  from "@components/NavHeader";
import { SiteFooter } from "@components/SiteFooter";
---

<Base
  title="Senior Marketing Manager Hamburg | Open to Work — Berk Saraloglu"
  description="Senior Marketing Manager seeking role in Hamburg or DACH. 11+ years at Samsung, BSH Siemens, VeSync. Available immediately."
  noIndex={false}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://saralogy.com" },
          { "@type": "ListItem", "position": 2, "name": "Open to Work", "item": "https://saralogy.com/open-to-work" }
        ]
      }
    ]
  })} />
  <Marquee client:load />
  <NavHeader client:load />

  <main>
    <!-- Hero -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-20 pb-14">
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-flex items-center gap-2 text-[11px] tracking-[0.2em] uppercase border border-border px-4 py-2" style="font-family: var(--font-body)">
            <span class="w-1.5 h-1.5 bg-foreground rounded-full animate-pulse"></span>
            Available now
          </span>
          <a href="/work" class="text-[11px] tracking-[0.2em] uppercase text-muted-foreground hover:text-foreground transition-colors duration-200" style="font-family: var(--font-body)">
            Looking for consulting? → /work
          </a>
        </div>
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-10">
          <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2.5rem, 6vw, 5.5rem); line-height: 0.95; letter-spacing: -0.03em;">
            Senior Marketing<br />
            <span class="italic font-light">Manager,</span><br />
            Hamburg.
          </h1>
          <div class="max-w-sm">
            <p class="text-sm text-muted-foreground leading-relaxed mb-6" style="font-family: var(--font-body)">
              11+ years building marketing infrastructure that delivers. Organic media scaled to €M+. 600% CRM growth. 117% launch targets. Looking for a Senior Marketing Manager role in Hamburg or DACH.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="mailto:berksaraloglu@gmail.com?subject=Senior%20Marketing%20role%20via%20saralogy.com"
                class="text-[11px] tracking-widest uppercase bg-foreground text-background px-5 py-2.5 hover:opacity-80 transition-opacity duration-200"
                style="font-family: var(--font-body)">
                Email Berk
              </a>
              <a href="https://linkedin.com/in/berksaraloglu" target="_blank" rel="noopener noreferrer"
                class="text-[11px] tracking-widest uppercase border border-border px-5 py-2.5 hover:border-foreground transition-colors duration-200 text-muted-foreground hover:text-foreground"
                style="font-family: var(--font-body)">
                LinkedIn ↗
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What I'm looking for -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-12" style="font-family: var(--font-body)">✦ What I'm looking for</span>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-px bg-border">
          {[
            { label: "Location", value: "Hamburg or DACH (no relocation)" },
            { label: "Role level", value: "Senior Marketing Manager or equivalent" },
            { label: "Start", value: "Available immediately" },
            { label: "Industry", value: "Consumer electronics, lifestyle, B2B SaaS, AI/tech" },
            { label: "Stage", value: "Scale-up to enterprise, team of 5+ in marketing" },
            { label: "Deal-breaker", value: "No dishonesty signals, no blame culture" },
          ].map(({ label, value }) => (
            <div class="bg-background p-6 flex flex-col gap-2">
              <span class="text-[10px] tracking-[0.2em] uppercase text-muted-foreground" style="font-family: var(--font-body)">{label}</span>
              <span style="font-family: var(--font-display); font-weight: 600; font-size: 1rem; letter-spacing: -0.01em;">{value}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- What I bring -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12">
          <h2 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;">What I bring.</h2>
          <p class="max-w-xs text-sm text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">Concrete patterns, not credentials. Here's what I'd do in the first 30 days.</p>
        </div>

        <div class="flex flex-col divide-y divide-border">
          {[
            { title: "Map the revenue story before touching a campaign", desc: "First 30 days: audit what's actually driving revenue versus what the team thinks is driving it. At VeSync I built 3 full-funnel playbooks from scratch using JTBD interviews. At BSH I restructured content production to save €1.5M annually while lifting organic reach across 10+ countries. I don't optimise channels before I understand the underlying customer logic." },
            { title: "Run launches end-to-end, including the uncomfortable parts", desc: "Ran the full-funnel launch of a premium airfryer at VeSync: 117% of sell-out target in 53 days across 8 channels simultaneously. That includes aligning category managers, briefing agencies, owning the budget, and delivering post-mortems without softening the numbers." },
            { title: "Manage cross-functional complexity without escalating everything", desc: "Led 15+ stakeholders across Germany and China HQ at VeSync without line authority. Aligned country teams across 10+ markets at BSH. The skill isn't influence tactics — it's building shared governance: joint OKRs, clear decision rights, and communication rhythms that don't collapse under pressure." },
            { title: "Use AI as infrastructure, not a content shortcut", desc: "Building vision-intelligence, an AI marketing platform for DACH SMEs, as a solo project alongside this job search. I can audit your current AI usage, identify three high-leverage automations, and have the first one running within the first month." },
          ].map(({ title, desc }, i) => (
            <div class="flex flex-col md:flex-row gap-4 py-8 group">
              <span class="text-[11px] tracking-widest text-muted-foreground w-10 shrink-0 pt-1" style="font-family: var(--font-body)">{String(i + 1).padStart(2, "0")}</span>
              <div class="md:w-1/3 shrink-0">
                <p style="font-family: var(--font-display); font-weight: 600; font-size: clamp(1rem, 1.5vw, 1.2rem); letter-spacing: -0.01em; line-height: 1.2;">{title}</p>
              </div>
              <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Honest answers -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-12" style="font-family: var(--font-body)">✦ A few honest answers</span>
        <div class="flex flex-col divide-y divide-border">
          {[
            { q: "Why did you leave VeSync?", a: "Relocation requirement, not performance. VeSync centralised European operations to Amsterdam. My family base is in Hamburg and my wife's nursing certification is tied to Germany until end of 2026. I could not relocate. The role was good; the geography didn't work." },
            { q: "Why are you looking now?", a: "I left in May 2026 to search properly rather than rush into the wrong role. I have an 18-month runway. I am not applying out of financial pressure. I am looking for the right fit — a company where marketing has real budget authority and the leadership team takes product seriously." },
            { q: "How long will you stay?", a: "I target 3 to 5 years in the right environment. My last two exits were structural, not motivational. I stay when I have scope, trust, and a team worth building with." },
            { q: "What about your German?", a: "B1 level, actively improving. At BSH Munich and VeSync Düsseldorf I operated in mixed-language environments and delivered results without requiring the team to work around a language gap." },
          ].map(({ q, a }) => (
            <div class="flex flex-col md:flex-row gap-4 py-6">
              <p class="md:w-1/3 shrink-0 text-[13px] font-medium text-foreground leading-relaxed" style="font-family: var(--font-body)">{q}</p>
              <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact CTA -->
    <section class="bg-foreground text-background">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-16 pb-8">
        <p style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 0.95; letter-spacing: -0.03em;" class="mb-10">
          Let's talk if<br /><span class="italic font-light">this fits.</span>
        </p>
        <div class="flex flex-wrap gap-4 mb-12">
          <a href="mailto:berksaraloglu@gmail.com?subject=Senior%20Marketing%20role%20via%20saralogy.com"
            class="text-[11px] tracking-widest uppercase bg-white text-black px-6 py-3 hover:bg-white/90 transition-opacity"
            style="font-family: var(--font-body)">
            Email Berk
          </a>
          <a href="https://cal.com/saralogy/15min" target="_blank" rel="noopener noreferrer"
            class="text-[11px] tracking-widest uppercase border border-white/30 px-6 py-3 hover:bg-white hover:text-black transition-all duration-200"
            style="font-family: var(--font-body)">
            Book 15 min
          </a>
          <a href="https://linkedin.com/in/berksaraloglu" target="_blank" rel="noopener noreferrer"
            class="text-[11px] tracking-widest uppercase border border-white/30 px-6 py-3 hover:bg-white hover:text-black transition-all duration-200 text-white/60 hover:text-black"
            style="font-family: var(--font-body)">
            LinkedIn ↗
          </a>
          <a href="/files/berk-saraloglu-cv.pdf" download
            class="text-[11px] tracking-widest uppercase border border-white/30 px-6 py-3 hover:bg-white hover:text-black transition-all duration-200 text-white/60 hover:text-black"
            style="font-family: var(--font-body)">
            Download CV ↓
          </a>
        </div>
        <div class="border-t border-white/10 pt-6">
          <p class="text-[11px] text-white/30 tracking-wider" style="font-family: var(--font-body)">
            berksaraloglu@gmail.com · I respond to specific enquiries within 48 hours.
          </p>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Base>
