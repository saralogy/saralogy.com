---
import Base from "@layouts/Base.astro";
import "../styles/global.css";
---

<Base
  title="Page not found — saralogy.com"
  description="This page doesn't exist."
  noIndex={true}
>
  <div class="min-h-screen flex items-center justify-center px-6 bg-grid">
    <div class="text-center max-w-md">
      <p class="eyebrow justify-center mb-4">404</p>
      <h1 class="display-heading text-5xl text-gray-950 mb-4">Page not found</h1>
      <p class="text-gray-600 mb-8">This page doesn't exist or has moved.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn-primary px-6 py-2.5">
          Go home
        </a>
        <a href="/about" class="btn-secondary px-6 py-2.5">
          About me
        </a>
      </div>
    </div>
  </div>
</Base>
