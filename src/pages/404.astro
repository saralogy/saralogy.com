---
import Base from "@layouts/Base.astro";
import "../styles/global.css";
---

<Base
  title="Page not found — saralogy.com"
  description="This page doesn't exist."
  noIndex={true}
>
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <p class="text-sm font-medium text-gray-500 mb-4">404</p>
      <h1 class="text-3xl font-bold text-gray-900 mb-4">Page not found</h1>
      <p class="text-gray-600 mb-8">This page doesn't exist or has moved.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="bg-gray-900 text-white px-6 py-2.5 rounded-full font-medium hover:bg-gray-700 transition-colors">
          Go home
        </a>
        <a href="/about" class="border border-gray-300 text-gray-700 px-6 py-2.5 rounded-full font-medium hover:border-gray-900 transition-colors">
          About me
        </a>
      </div>
    </div>
  </div>
</Base>
