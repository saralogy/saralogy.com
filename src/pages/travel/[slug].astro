---
import { getCollection, type CollectionEntry } from "astro:content";
import Base from "@layouts/Base.astro";
import "../../styles/global.css";
import { Marquee }    from "@components/Marquee";
import { NavHeader }  from "@components/NavHeader";
import { SiteFooter } from "@components/SiteFooter";

type TripEntry = CollectionEntry<"trips">;

export async function getStaticPaths() {
  const trips = await getCollection(
    "trips",
    ({ data }) => data.status === "published",
  );
  return trips.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: TripEntry;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;

const MONTHS: readonly string[] = [
  "Jan", "Feb", "Mar", "Apr", "May", "Jun",
  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
];

const VISITED_AT_RE = /^(\d{4})-(\d{2})$/;

function formatVisitedAt(value: string): string {
  const match = VISITED_AT_RE.test(value) ? value.split("-") : null;
  if (!match) return value;
  const year = Number(match[0]);
  const month = Number(match[1]);
  if (!Number.isFinite(year) || month < 1 || month > 12) return value;
  return `${MONTHS[month - 1]} ${year}`;
}

const tripUrl = `https://saralogy.com/travel/${entry.slug}`;
const datePublished = d.visitedAt.length === 7 ? `${d.visitedAt}-01` : d.visitedAt;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "headline": d.title,
      "description": d.highlight,
      "datePublished": datePublished,
      "url": tripUrl,
      "image": {
        "@type": "ImageObject",
        "url": d.seo.ogImage ?? "https://saralogy.com/og-default.png",
        "width": 1200,
        "height": 630,
      },
      "author": { "@id": "https://saralogy.com/#person" },
      "publisher": { "@id": "https://saralogy.com/#person" },
      "inLanguage": "en",
      "about": { "@type": "Place", "name": d.title },
      "mainEntityOfPage": { "@type": "WebPage", "@id": tripUrl },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://saralogy.com" },
        { "@type": "ListItem", "position": 2, "name": "Travel", "item": "https://saralogy.com/travel" },
        { "@type": "ListItem", "position": 3, "name": d.title, "item": tripUrl },
      ],
    },
  ],
};
---

<Base
  title={d.seo.title}
  description={d.seo.description}
  ogImage={d.seo.ogImage}
  noIndex={d.seo.noIndex}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Marquee client:load />
  <NavHeader client:load />

  <main>
    <!-- Header -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-16 pb-14">
        <a
          href="/travel"
          class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase text-muted-foreground hover:text-foreground transition-colors mb-10"
          style="font-family: var(--font-body)"
        >
          <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M5 1L1 4.5m0 0L5 8M1 4.5h10" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
          Travel
        </a>

        <div class="max-w-3xl">
          <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2.5rem, 6vw, 5.5rem); line-height: 0.95; letter-spacing: -0.03em;">
            {d.title}
          </h1>

          <div class="flex flex-wrap items-center gap-3 mt-8">
            <span class="text-[11px] tracking-[0.2em] uppercase text-muted-foreground" style="font-family: var(--font-body)">
              {formatVisitedAt(d.visitedAt)}
            </span>
            {d.visitCount > 1 && (
              <>
                <span class="text-muted-foreground/40 text-[11px]">·</span>
                <span class="text-[11px] tracking-[0.2em] uppercase text-muted-foreground" style="font-family: var(--font-body)">
                  x {d.visitCount} visits
                </span>
              </>
            )}
            <span class="text-[10px] tracking-[0.15em] uppercase border border-border px-2.5 py-1 text-muted-foreground" style="font-family: var(--font-body)">
              {d.level}
            </span>
          </div>

          <p
            class="text-muted-foreground mt-8 leading-relaxed"
            style="font-family: var(--font-body); font-size: clamp(1.05rem, 1.5vw, 1.25rem);"
          >
            {d.highlight}
          </p>
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div
          class="max-w-2xl prose prose-sm text-muted-foreground"
          style="font-family: var(--font-body); font-size: 0.875rem; line-height: 1.8;"
        >
          <Content />
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-foreground text-background">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <p style="font-family: var(--font-display); font-weight: 700; font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1; letter-spacing: -0.02em;">
          Interested in<br /><span class="italic font-light">what I build?</span>
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/work"
            class="text-[11px] tracking-widest uppercase bg-white text-black px-6 py-3 hover:bg-white/90 transition-opacity"
            style="font-family: var(--font-body)"
          >
            Work with me
          </a>
          <a
            href="/travel"
            class="text-[11px] tracking-widest uppercase text-white/50 hover:text-white transition-colors self-center"
            style="font-family: var(--font-body)"
          >
            All travel
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Base>
