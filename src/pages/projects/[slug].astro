---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import "../../styles/global.css";
import { Marquee }    from "@components/Marquee";
import { NavHeader }  from "@components/NavHeader";
import { SiteFooter } from "@components/SiteFooter";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => data.status === "published");
  return projects.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props { entry: { slug: string; data: any; render: () => Promise<{ Content: any }> } }
const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;

const STATUS_LABEL: Record<string, string> = {
  concept: "Concept", mvp: "MVP", beta: "Beta", live: "Live", archived: "Archived",
};
---

<Base title={d.seo.title} description={d.seo.description} ogImage={d.seo.ogImage}>
  <Marquee client:load />
  <NavHeader client:load />

  <main>
    <!-- Header -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 pt-16 pb-14">
        <a href="/projects" class="inline-flex items-center gap-2 text-[11px] tracking-widest uppercase text-muted-foreground hover:text-foreground transition-colors mb-10" style="font-family: var(--font-body)">
          <svg width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M5 1L1 4.5m0 0L5 8M1 4.5h10" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
          Projects
        </a>

        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-10">
          <div>
            <span class="text-[10px] tracking-[0.2em] uppercase border border-border px-2.5 py-1 text-muted-foreground inline-block mb-4" style="font-family: var(--font-body)">
              {STATUS_LABEL[d.projectStatus] ?? d.projectStatus}
            </span>
            <h1 style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2.5rem, 6vw, 5.5rem); line-height: 0.95; letter-spacing: -0.03em;">
              {d.title}.
            </h1>
            <p class="text-muted-foreground mt-3" style="font-family: var(--font-body); font-size: clamp(1rem, 1.5vw, 1.2rem);">{d.tagline}</p>
          </div>

          <div class="flex flex-wrap gap-4 shrink-0">
            {d.liveUrl && (
              <a href={d.liveUrl} target="_blank" rel="noopener noreferrer"
                class="text-[11px] tracking-widest uppercase bg-foreground text-background px-5 py-2.5 hover:opacity-80 transition-opacity"
                style="font-family: var(--font-body)">
                Visit ↗
              </a>
            )}
            {d.waitlistUrl && (
              <a href={d.waitlistUrl} target="_blank" rel="noopener noreferrer"
                class="text-[11px] tracking-widest uppercase border border-border px-5 py-2.5 hover:border-foreground text-muted-foreground hover:text-foreground transition-all"
                style="font-family: var(--font-body)">
                Join waitlist
              </a>
            )}
            {d.githubUrl && (
              <a href={d.githubUrl} target="_blank" rel="noopener noreferrer"
                class="text-[11px] tracking-widest uppercase border border-border px-5 py-2.5 hover:border-foreground text-muted-foreground hover:text-foreground transition-all"
                style="font-family: var(--font-body)">
                GitHub ↗
              </a>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- Problem / Audience / Proof -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border">
          <div class="bg-background p-8 flex flex-col gap-3">
            <span class="text-[10px] tracking-[0.2em] uppercase text-muted-foreground" style="font-family: var(--font-body)">Problem</span>
            <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{d.problem}</p>
          </div>
          <div class="bg-background p-8 flex flex-col gap-3">
            <span class="text-[10px] tracking-[0.2em] uppercase text-muted-foreground" style="font-family: var(--font-body)">Audience</span>
            <p class="text-[13px] text-muted-foreground leading-relaxed" style="font-family: var(--font-body)">{d.audience}</p>
          </div>
          {d.proofPoint ? (
            <div class="bg-background p-8 flex flex-col gap-3 border-l-2 border-foreground">
              <span class="text-[10px] tracking-[0.2em] uppercase text-muted-foreground" style="font-family: var(--font-body)">Current proof</span>
              <p class="text-[13px] text-foreground font-medium leading-relaxed" style="font-family: var(--font-body)">{d.proofPoint}</p>
            </div>
          ) : (
            <div class="bg-background p-8" />
          )}
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="border-b border-border">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-20 md:py-28">
        <div class="max-w-2xl prose prose-sm text-muted-foreground" style="font-family: var(--font-body); font-size: 0.875rem; line-height: 1.8;">
          <Content />
        </div>
      </div>
    </section>

    <!-- Tech stack -->
    {d.techStack && d.techStack.length > 0 && (
      <section class="border-b border-border">
        <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-12">
          <span class="text-[11px] tracking-[0.25em] uppercase text-muted-foreground block mb-6" style="font-family: var(--font-body)">✦ Tech stack</span>
          <div class="flex flex-wrap gap-2">
            {d.techStack.map((tech: string) => (
              <span class="text-[10px] tracking-[0.15em] uppercase border border-border px-3 py-1.5 text-muted-foreground" style="font-family: var(--font-body)">{tech}</span>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="bg-foreground text-background">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <p style="font-family: var(--font-display); font-weight: 700; font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1; letter-spacing: -0.02em;">
          See how these tools<br /><span class="italic font-light">would help you build.</span>
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/work"
            class="text-[11px] tracking-widest uppercase bg-white text-black px-6 py-3 hover:bg-white/90 transition-opacity"
            style="font-family: var(--font-body)">
            Work with me
          </a>
          <a href="/projects"
            class="text-[11px] tracking-widest uppercase text-white/50 hover:text-white transition-colors"
            style="font-family: var(--font-body)">
            ← All projects
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Base>
