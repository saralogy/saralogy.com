---
---

<header class="border-b border-gray-100 sticky top-0 bg-white/90 backdrop-blur z-40">
  <nav class="max-w-4xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <a href="/" class="font-semibold text-lg tracking-tight">saralogy.com</a>

      <!-- Desktop nav -->
      <div class="hidden sm:flex items-center gap-6 text-sm text-gray-600">
        <a href="/about" class="hover:text-gray-900 transition-colors">About</a>
        <a href="/career" class="hover:text-gray-900 transition-colors">Career</a>
        <a href="/projects" class="hover:text-gray-900 transition-colors">Projects</a>
        <a href="/work" class="bg-gray-900 text-white px-4 py-1.5 rounded-full text-sm font-medium hover:bg-gray-700 transition-colors">
          Work with me
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        class="sm:hidden p-2 text-gray-600 hover:text-gray-900 transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile nav (hidden by default) -->
    <div
      id="mobile-menu"
      class="hidden sm:hidden mt-4 pb-4 border-t border-gray-100 pt-4 space-y-3"
    >
      <a href="/about" class="block text-sm text-gray-600 hover:text-gray-900 transition-colors py-2">About</a>
      <a href="/career" class="block text-sm text-gray-600 hover:text-gray-900 transition-colors py-2">Career</a>
      <a href="/projects" class="block text-sm text-gray-600 hover:text-gray-900 transition-colors py-2">Projects</a>
      <a href="/work" class="block bg-gray-900 text-white px-4 py-2 rounded-full text-sm font-medium hover:bg-gray-700 transition-colors text-center">
        Work with me
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });

    // Close menu when a link is clicked
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
      });
    });
  }
</script>
