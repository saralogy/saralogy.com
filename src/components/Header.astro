---
export interface Props {
  dark?: boolean;
}

const { dark = false } = Astro.props;

const headerClass = dark
  ? "border-b border-white/10 sticky top-0 bg-[#546E7A]/90 backdrop-blur z-40"
  : "border-b border-gray-100 sticky top-0 bg-white/90 backdrop-blur z-40";

const logoClass = dark
  ? "font-semibold text-lg tracking-tight text-white"
  : "font-semibold text-lg tracking-tight";

const desktopNavWrapClass = dark
  ? "hidden sm:flex items-center gap-6 text-sm text-white/70"
  : "hidden sm:flex items-center gap-6 text-sm text-gray-600";

const navLinkClass = dark
  ? "uppercase tracking-wider text-[11px] font-medium text-white/70 hover:text-white transition-colors"
  : "uppercase tracking-wider text-[11px] font-medium text-gray-600 hover:text-gray-900 transition-colors";

const ctaClass = dark
  ? "bg-white text-gray-900 px-4 py-1.5 rounded-full text-sm font-medium hover:bg-gray-100 transition-colors"
  : "bg-gray-900 text-white px-4 py-1.5 rounded-full text-sm font-medium hover:bg-gray-700 transition-colors";

const hamburgerClass = dark
  ? "sm:hidden p-2 text-white hover:text-white/80 transition-colors"
  : "sm:hidden p-2 text-gray-600 hover:text-gray-900 transition-colors";

const mobileMenuClass = dark
  ? "hidden sm:hidden mt-4 pb-4 border-t border-white/10 pt-4 space-y-3 bg-[#546E7A]"
  : "hidden sm:hidden mt-4 pb-4 border-t border-gray-100 pt-4 space-y-3";

const mobileNavLinkClass = dark
  ? "block uppercase tracking-wider text-[11px] font-medium text-white/70 hover:text-white transition-colors py-2"
  : "block uppercase tracking-wider text-[11px] font-medium text-gray-600 hover:text-gray-900 transition-colors py-2";

const mobileCtaClass = dark
  ? "block bg-white text-gray-900 px-4 py-2 rounded-full text-sm font-medium hover:bg-gray-100 transition-colors text-center"
  : "block bg-gray-900 text-white px-4 py-2 rounded-full text-sm font-medium hover:bg-gray-700 transition-colors text-center";
---

<header class={headerClass}>
  <nav class="max-w-4xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <a href="/" class={logoClass}>saralogy.com</a>

      <!-- Desktop nav -->
      <div class={desktopNavWrapClass}>
        <a href="/about" class={navLinkClass}>About</a>
        <a href="/career" class={navLinkClass}>Career</a>
        <a href="/projects" class={navLinkClass}>Projects</a>
        <a href="/work" class={ctaClass}>
          Work with me
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        class={hamburgerClass}
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile nav (hidden by default) -->
    <div
      id="mobile-menu"
      class={mobileMenuClass}
    >
      <a href="/about" class={mobileNavLinkClass}>About</a>
      <a href="/career" class={mobileNavLinkClass}>Career</a>
      <a href="/projects" class={mobileNavLinkClass}>Projects</a>
      <a href="/work" class={mobileCtaClass}>
        Work with me
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });

    // Close menu when a link is clicked
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
      });
    });
  }
</script>
