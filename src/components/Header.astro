---
export interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;
const path = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
}
---

<header class="site-header" data-dark={dark ? "true" : undefined}>
  <nav class="nav-inner">
    <a href="/" class="nav-logo">
      <span class="logo-mark" aria-hidden="true"></span>
      saralogy.com
    </a>

    <!-- Desktop nav -->
    <ul class="desktop-links" role="list">
      <li><a href="/about"    class:list={["nav-link", { active: isActive('/about')    }]}>About</a></li>
      <li><a href="/career"   class:list={["nav-link", { active: isActive('/career')   }]}>Career</a></li>
      <li><a href="/projects" class:list={["nav-link", { active: isActive('/projects') }]}>Projects</a></li>
      <li>
        <a href="/work" class:list={["nav-cta", { active: isActive('/work') }]}>
          Work with me
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button
      class="menu-toggle"
      id="menu-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="icon-open"  width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      <svg class="icon-close" width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" role="dialog" aria-label="Navigation">
    <ul role="list">
      <li><a href="/about"    class:list={["mob-link", { active: isActive('/about')    }]}>About</a></li>
      <li><a href="/career"   class:list={["mob-link", { active: isActive('/career')   }]}>Career</a></li>
      <li><a href="/projects" class:list={["mob-link", { active: isActive('/projects') }]}>Projects</a></li>
      <li><a href="/work"     class:list={["mob-cta",  { active: isActive('/work')     }]}>Work with me</a></li>
    </ul>
  </div>
</header>

<style>
  /* ── Structure ─────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    border-bottom: 1px solid #f3f4f6;
    background: rgba(255, 255, 255, 0.90);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: background 0.3s, border-color 0.3s;
  }

  .site-header[data-dark="true"] {
    border-bottom-color: rgba(255, 255, 255, 0.10);
    background: rgba(84, 110, 122, 0.92);
  }

  .nav-inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ── Logo ──────────────────────────────────────────────────── */
  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #111827;
    text-decoration: none;
    transition: color 0.2s;
  }
  .site-header[data-dark="true"] .nav-logo { color: white; }

  .logo-mark {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: linear-gradient(135deg, #c8911f, #546E7A);
    box-shadow: 0 0 0 4px rgba(84, 110, 122, 0.08);
  }

  /* ── Desktop links ─────────────────────────────────────────── */
  .desktop-links {
    display: flex;
    align-items: center;
    gap: 24px;
    list-style: none;
  }

  .nav-link {
    font-size: 0.75rem;          /* 12px — accessibility minimum */
    font-weight: 500;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: #6B7280;
    text-decoration: none;
    position: relative;
    padding-bottom: 2px;
    transition: color 0.15s;
  }
  .nav-link:hover { color: #111827; }

  /* Active state — underline indicator */
  .nav-link.active {
    color: #546E7A;
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0; right: 0;
    height: 2px;
    background: #546E7A;
    border-radius: 1px;
  }

  /* Dark mode overrides */
  .site-header[data-dark="true"] .nav-link       { color: rgba(255,255,255,0.60); }
  .site-header[data-dark="true"] .nav-link:hover { color: white; }
  .site-header[data-dark="true"] .nav-link.active { color: white; }
  .site-header[data-dark="true"] .nav-link.active::after { background: white; }

  /* ── CTA pill ──────────────────────────────────────────────── */
  .nav-cta {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    background: #111827;
    color: white;
    padding: 8px 18px;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
    white-space: nowrap;
    box-shadow: 0 4px 14px -6px rgba(17, 24, 39, 0.35);
  }
  .nav-cta:hover    { background: #374151; transform: translateY(-1px); }
  .nav-cta.active   { background: linear-gradient(135deg, #546E7A, #2c4450); }

  .site-header[data-dark="true"] .nav-cta         { background: white; color: #111827; }
  .site-header[data-dark="true"] .nav-cta:hover   { background: rgba(255,255,255,0.85); }

  /* ── Mobile toggle button ──────────────────────────────────── */
  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    color: #4B5563;
    line-height: 0;
    transition: color 0.15s;
  }
  .menu-toggle:hover { color: #111827; }
  .site-header[data-dark="true"] .menu-toggle       { color: rgba(255,255,255,0.80); }
  .site-header[data-dark="true"] .menu-toggle:hover { color: white; }

  /* Toggle icon state */
  .icon-close { display: none; }
  .menu-toggle[aria-expanded="true"] .icon-open  { display: none; }
  .menu-toggle[aria-expanded="true"] .icon-close { display: block; }

  /* ── Mobile menu ───────────────────────────────────────────── */
  .mobile-menu {
    display: none;
    border-top: 1px solid #f3f4f6;
    padding: 12px 24px 20px;
  }
  .mobile-menu.is-open { display: block; }

  .site-header[data-dark="true"] .mobile-menu {
    border-top-color: rgba(255,255,255,0.10);
    background: rgba(84,110,122,0.96);
  }

  .mobile-menu ul { list-style: none; display: flex; flex-direction: column; gap: 4px; }

  .mob-link {
    display: block;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #4B5563;
    text-decoration: none;
    padding: 10px 0;
    border-bottom: 1px solid #F3F4F6;
    transition: color 0.15s;
  }
  .mob-link:last-of-type { border-bottom: none; }
  .mob-link:hover  { color: #111827; }
  .mob-link.active { color: #546E7A; font-weight: 600; }

  .site-header[data-dark="true"] .mob-link         { color: rgba(255,255,255,0.65); border-bottom-color: rgba(255,255,255,0.08); }
  .site-header[data-dark="true"] .mob-link:hover   { color: white; }
  .site-header[data-dark="true"] .mob-link.active  { color: white; }

  .mob-cta {
    display: block;
    margin-top: 12px;
    background: #111827;
    color: white;
    padding: 12px 18px;
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    text-align: center;
    transition: background 0.15s;
  }
  .mob-cta:hover  { background: #374151; }
  .mob-cta.active { background: #546E7A; }

  .site-header[data-dark="true"] .mob-cta { background: white; color: #111827; }

  /* ── Responsive breakpoint ─────────────────────────────────── */
  @media (max-width: 639px) {
    .desktop-links { display: none; }
    .menu-toggle   { display: block; }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('is-open');
  });

  // Close on nav link click (mobile UX)
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      menu.classList.remove('is-open');
    });
  });
</script>
